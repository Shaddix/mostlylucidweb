{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=mostlylucid;Username=postgres;Password=postgres"
  },
  "Analytics": {
    "UmamiPath": "https://umami.mostlylucid.net",
    "WebsiteId": "",
    "UmamiScript": "getinfo"
  },
  "Blog": {
    "Mode": "Database"
  },
  "SmtpSettings": {
    "Server": "smtp.example.com",
    "Port": 587,
    "UserName": "",
    "Password": "",
    "SenderEmail": "ai@mostlylucid.ai",
    "SenderName": "Mostlylucid AI"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Error",
        "Npgsql": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/mostlylucid-ai-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "Mostlylucid.AI"
    }
  }
}
