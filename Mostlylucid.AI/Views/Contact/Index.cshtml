@model ContactViewModel
@{
    ViewBag.Title = "Contact";
}

<!-- Hero Section -->
<section class="bg-ai-gradient text-white py-16 lg:py-20">
    <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
            <h1 class="text-4xl lg:text-5xl font-bold mb-4">Get in Touch</h1>
            <p class="text-xl text-indigo-100">
                Let's discuss how AI can help your business
            </p>
        </div>
    </div>
</section>

<!-- Contact Form Section -->
<section class="py-16 lg:py-24 bg-light-bg dark:bg-dark-bg">
    <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
                <!-- Contact Info -->
                <div class="lg:col-span-1">
                    <h2 class="text-xl font-bold text-primary dark:text-white mb-6">Contact Information</h2>

                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="w-10 h-10 bg-secondary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                                <i class="bx bx-envelope text-xl text-secondary"></i>
                            </div>
                            <div>
                                <h3 class="font-semibold text-primary dark:text-white">Email</h3>
                                <a href="mailto:ai@mostlylucid.ai" class="text-secondary hover:text-accent transition-colors">
                                    ai@mostlylucid.ai
                                </a>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="w-10 h-10 bg-secondary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                                <i class="bx bxl-github text-xl text-secondary"></i>
                            </div>
                            <div>
                                <h3 class="font-semibold text-primary dark:text-white">GitHub</h3>
                                <a href="https://github.com/scottgal" target="_blank" rel="noopener noreferrer"
                                   class="text-secondary hover:text-accent transition-colors">
                                    github.com/scottgal
                                </a>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="w-10 h-10 bg-secondary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                                <i class="bx bxl-linkedin text-xl text-secondary"></i>
                            </div>
                            <div>
                                <h3 class="font-semibold text-primary dark:text-white">LinkedIn</h3>
                                <a href="https://www.linkedin.com/in/scottgalloway/" target="_blank" rel="noopener noreferrer"
                                   class="text-secondary hover:text-accent transition-colors">
                                    Scott Galloway
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="mt-8 p-4 bg-white dark:bg-dark-surface rounded-lg shadow-md">
                        <h3 class="font-semibold text-primary dark:text-white mb-2">What to Expect</h3>
                        <p class="text-slate-600 dark:text-slate-400 text-sm">
                            I'll respond within 24-48 hours. We'll start with a brief call to understand your needs,
                            followed by a proposal if there's a good fit.
                        </p>
                    </div>
                </div>

                <!-- Form -->
                <div class="lg:col-span-2">
                    <div class="bg-white dark:bg-dark-surface rounded-xl shadow-md p-6 lg:p-8"
                         x-data="contactForm()">

                        <form x-show="!submitted" x-on:submit.prevent="submitForm">
                            @Html.AntiForgeryToken()

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <!-- Name -->
                                <div>
                                    <label class="form-label-ai" for="name">Name *</label>
                                    <input type="text" id="name" x-model="formData.name" required
                                           class="form-input-ai" placeholder="Your name">
                                </div>

                                <!-- Email -->
                                <div>
                                    <label class="form-label-ai" for="email">Email *</label>
                                    <input type="email" id="email" x-model="formData.email" required
                                           class="form-input-ai" placeholder="you@example.com">
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                                <!-- Company -->
                                <div>
                                    <label class="form-label-ai" for="company">Company</label>
                                    <input type="text" id="company" x-model="formData.company"
                                           class="form-input-ai" placeholder="Company name (optional)">
                                </div>

                                <!-- Project Type -->
                                <div>
                                    <label class="form-label-ai" for="projectType">Project Type *</label>
                                    <select id="projectType" x-model="formData.projectType" required
                                            class="form-input-ai">
                                        <option value="">Select a project type</option>
                                        <option value="rag">RAG / Document Q&A</option>
                                        <option value="local-llm">Local LLM Deployment</option>
                                        <option value="document-intel">Document Intelligence</option>
                                        <option value="semantic-search">Semantic Search</option>
                                        <option value="ai-strategy">AI Strategy Consulting</option>
                                        <option value="custom">Custom AI Solution</option>
                                        <option value="other">Other</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Message -->
                            <div class="mt-6">
                                <label class="form-label-ai" for="message">Message *</label>
                                <textarea id="message" x-model="formData.message" required
                                          rows="5" class="form-input-ai"
                                          placeholder="Tell me about your project, goals, and any specific challenges you're facing..."></textarea>
                            </div>

                            <!-- Error Message -->
                            <div x-show="error" x-cloak class="mt-4 p-4 bg-red-50 dark:bg-red-900/20 rounded-lg text-red-600 dark:text-red-400">
                                <span x-text="error"></span>
                            </div>

                            <!-- Submit Button -->
                            <div class="mt-6">
                                <button type="submit"
                                        class="btn btn-primary w-full md:w-auto"
                                        :disabled="submitting"
                                        :class="{ 'opacity-50 cursor-not-allowed': submitting }">
                                    <span x-show="!submitting">Send Message</span>
                                    <span x-show="submitting" x-cloak class="flex items-center gap-2">
                                        <span class="loading loading-spinner loading-sm"></span>
                                        Sending...
                                    </span>
                                </button>
                            </div>
                        </form>

                        <!-- Success Message -->
                        <div x-show="submitted" x-cloak class="text-center py-12">
                            <div class="w-16 h-16 bg-green-100 dark:bg-green-900/20 rounded-full flex items-center justify-center mx-auto mb-4">
                                <i class="bx bx-check text-4xl text-green-600 dark:text-green-400"></i>
                            </div>
                            <h3 class="text-xl font-semibold text-primary dark:text-white mb-2">Message Sent!</h3>
                            <p class="text-slate-600 dark:text-slate-400 mb-6">
                                Thank you for reaching out. I'll get back to you within 24-48 hours.
                            </p>
                            <button x-on:click="resetForm()" class="btn btn-outline btn-secondary">
                                Send Another Message
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
