<Window x:Class="Mostlylucid.Chat.TrayApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="Chat with Scott - Admin" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged">

    <!-- System Tray Icon -->
    <Window.Resources>
        <tb:TaskbarIcon x:Key="TrayIcon"
                        IconSource="app.ico"
                        ToolTipText="Chat with Scott - Admin"
                        TrayLeftMouseDown="TrayIcon_TrayLeftMouseDown">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open" Click="MenuOpen_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="MenuExit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Conversations List -->
        <Grid Grid.Column="0" Background="#F9FAFB">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#667eea" Padding="20">
                <StackPanel>
                    <TextBlock Text="Active Chats" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="ConnectionStatus" Text="Connecting..." FontSize="12" Foreground="White" Opacity="0.9" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Conversations -->
            <ListBox x:Name="ConversationsList"
                     Grid.Row="1"
                     SelectionChanged="ConversationsList_SelectionChanged"
                     BorderThickness="0"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="15,10" BorderThickness="0,0,0,1" BorderBrush="#E5E7EB">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding UserName}" FontWeight="SemiBold" FontSize="14"/>
                                    <TextBlock Text="{Binding UserEmail}" FontSize="12" Foreground="#6B7280" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding LastMessageAt, StringFormat='Last: {0:HH:mm}'}" FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Background="#EF4444"
                                        CornerRadius="10"
                                        Padding="8,4"
                                        Visibility="{Binding UnreadCount, Converter={StaticResource UnreadToVisibilityConverter}}">
                                    <TextBlock Text="{Binding UnreadCount}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Admin Info -->
            <Border Grid.Row="2" Background="White" Padding="20" BorderThickness="0,1,0,0" BorderBrush="#E5E7EB">
                <StackPanel>
                    <TextBlock x:Name="AdminNameText" Text="Scott" FontWeight="SemiBold"/>
                    <TextBlock Text="Admin" FontSize="12" Foreground="#6B7280"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Chat Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Chat Header -->
            <Border Grid.Row="0" Background="White" Padding="20" BorderThickness="0,0,0,1" BorderBrush="#E5E7EB">
                <StackPanel x:Name="ChatHeader" Visibility="Collapsed">
                    <TextBlock x:Name="ChatUserName" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ChatUserEmail" FontSize="13" Foreground="#6B7280" Margin="0,2,0,0"/>
                    <TextBlock x:Name="ChatSourceUrl" FontSize="12" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                </StackPanel>
                <TextBlock x-Name="NoChatSelected" Text="Select a conversation to start chatting" FontSize="16" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
            </Border>

            <!-- Messages -->
            <ScrollViewer Grid.Row="1" x:Name="MessagesScrollViewer" VerticalScrollBarVisibility="Auto" Background="#F9FAFB">
                <ItemsControl x:Name="MessagesList" Padding="20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Admin Message (Left) -->
                                <StackPanel Grid.Column="0"
                                           Orientation="Horizontal"
                                           HorizontalAlignment="Left"
                                           Visibility="{Binding SenderType, Converter={StaticResource AdminMessageVisibilityConverter}}">
                                    <Border Width="32" Height="32" Background="#10B981" CornerRadius="16" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Initials}" Foreground="White" FontWeight="SemiBold"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel MaxWidth="400">
                                        <Border Background="White" Padding="12" CornerRadius="12,12,12,4">
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="14"/>
                                        </Border>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                  FontSize="11" Foreground="#6B7280" Margin="4,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- User Message (Right) -->
                                <StackPanel Grid.Column="1"
                                           Orientation="Horizontal"
                                           HorizontalAlignment="Right"
                                           Visibility="{Binding SenderType, Converter={StaticResource UserMessageVisibilityConverter}}">
                                    <StackPanel MaxWidth="400">
                                        <Border Background="#667eea" Padding="12" CornerRadius="12,12,4,12">
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="14" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                  FontSize="11" Foreground="#6B7280" Margin="0,4,4,0" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                    <Border Width="32" Height="32" Background="#667eea" CornerRadius="16" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Initials}" Foreground="White" FontWeight="SemiBold"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Input -->
            <Border Grid.Row="2" Background="White" Padding="20" BorderThickness="0,1,0,0" BorderBrush="#E5E7EB">
                <Grid x:Name="ChatInput" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="MessageInput"
                             Grid.Column="0"
                             FontSize="14"
                             Padding="12"
                             VerticalContentAlignment="Center"
                             BorderBrush="#D1D5DB"
                             BorderThickness="1"
                             KeyDown="MessageInput_KeyDown"/>

                    <Button Grid.Column="1"
                            Content="Send"
                            Click="SendButton_Click"
                            Margin="10,0,0,0"
                            Padding="20,10"
                            Background="#667eea"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
