{
  "name": "@mostlylucid/mermaid-enhancements",
  "version": "1.0.0",
  "description": "Enhance Mermaid.js diagrams with interactive pan/zoom, fullscreen lightbox, export to PNG/SVG, and automatic theme switching",
  "main": "dist/index.js",
  "module": "src/index.ts",
  "types": "src/types.ts",
  "exports": {
    ".": {
      "types": "./src/types.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js"
    },
    "./bundle": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.bundle.min.js",
      "require": "./dist/index.umd.js"
    },
    "./min": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.min.js",
      "require": "./dist/index.min.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "unpkg": "dist/index.bundle.min.js",
  "jsdelivr": "dist/index.bundle.min.js",
  "files": [
    "src/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "minify": "node scripts/minify.js",
    "bundle": "rollup -c",
    "build:all": "npm run build && npm run minify && npm run bundle",
    "prepublishOnly": "npm run build:all",
    "dev": "cd examples && npx http-server -p 2000 -o",
    "dev:demo": "npx http-server -p 2000 -o examples/demo.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "verify-cdn": "bash scripts/verify-cdn.sh",
    "publish:patch": "node -e \"process.platform === 'win32' ? require('child_process').execSync('scripts\\\\publish.bat patch', {stdio: 'inherit'}) : require('child_process').execSync('bash scripts/publish.sh patch', {stdio: 'inherit'})\"",
    "publish:minor": "node -e \"process.platform === 'win32' ? require('child_process').execSync('scripts\\\\publish.bat minor', {stdio: 'inherit'}) : require('child_process').execSync('bash scripts/publish.sh minor', {stdio: 'inherit'})\"",
    "publish:major": "node -e \"process.platform === 'win32' ? require('child_process').execSync('scripts\\\\publish.bat major', {stdio: 'inherit'}) : require('child_process').execSync('bash scripts/publish.sh major', {stdio: 'inherit'})\""
  },
  "keywords": [
    "mermaid",
    "mermaidjs",
    "diagram",
    "chart",
    "visualization",
    "pan",
    "zoom",
    "export",
    "svg",
    "png",
    "lightbox",
    "fullscreen",
    "theme",
    "dark-mode"
  ],
  "author": "Mostlylucid",
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "https://github.com/scottgal/mostlylucidweb.git",
    "directory": "mostlylucid-mermaid"
  },
  "bugs": {
    "url": "https://github.com/scottgal/mostlylucidweb/issues"
  },
  "homepage": "https://github.com/scottgal/mostlylucidweb/tree/main/mostlylucid-mermaid#readme",
  "peerDependencies": {
    "mermaid": "^10.0.0 || ^11.0.0"
  },
  "dependencies": {
    "html-to-image": "^1.11.11",
    "svg-pan-zoom": "^3.6.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^20.19.24",
    "@vitest/ui": "^4.0.8",
    "happy-dom": "^20.0.10",
    "http-server": "^14.1.1",
    "jsdom": "^27.1.0",
    "rollup": "^4.53.1",
    "terser": "^5.44.1",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
