{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "EmbeddingModel": "nomic-embed-text"
  },
  "BackgroundWorkers": {
    "Enabled": false,
    "JobPollIntervalSeconds": 1,
    "OutboxPollIntervalSeconds": 5,
    "Queues": ["default", "embeddings", "events"]
  },
  "ClientFingerprint": {
    "Enabled": true,
    "Endpoint": "/api/fingerprint",
    "HmacKey": "",
    "CollectWebGL": true,
    "CollectCanvas": true,
    "CollectAudio": true,
    "Timeout": 5000
  },
  "Cache": {
    "UseRedis": false,
    "InstanceName": "SegmentCommerce_"
  }
}
