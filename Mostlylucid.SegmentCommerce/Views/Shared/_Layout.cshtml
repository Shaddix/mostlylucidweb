<!DOCTYPE html>
<html lang="en" 
      x-data="sessionStore()" 
      x-init="init()"
      :class="{ 'dark': darkMode }">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SegmentCommerce</title>
    
    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="~/css/dist/main.css" />
    
    <!-- HTMX with preload extension -->
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/htmx-ext-preload@2.1.0/preload.js"></script>
    
    <!-- Tracking Manager - must load BEFORE session-store.js -->
    <script src="~/js/tracking-manager.js"></script>
    
    <!-- Session store - must load BEFORE Alpine.js -->
    <script src="~/js/session-store.js"></script>
    
    <!-- Search component for header -->
    <script src="~/js/search-component.js"></script>
    
    <!-- Alpine.js - must load after HTMX for integration -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js"></script>
    
    <!-- XSRF Token for HTMX -->
    @Html.AntiForgeryToken()
    <meta name="xsrf-token" content="@(Context.RequestServices.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>()?.GetTokens(Context).RequestToken)" />
    
    <!-- Session Config - enables cookieless session tracking -->
    <!-- Server embeds session token in page, JS reads and sends in headers -->
    <!-- Using custom element to avoid Htmx.TagHelpers interference -->
    <sc-session></sc-session>
</head>
<body class="min-h-screen bg-shop-surface dark:bg-shop-surface-dark text-gray-900 dark:text-gray-100 transition-colors duration-300"
      hx-boost="true"
      hx-target="#main-content"
      hx-swap="innerHTML show:window:top"
      hx-push-url="true"
      hx-ext="preload">
    <!-- Header -->
    <header class="sticky top-0 z-40 bg-white dark:bg-gray-900 shadow-sm">
        <nav class="container mx-auto px-4 py-3">
            <div class="flex items-center justify-between">
                <!-- Logo -->
                <a href="/" class="flex items-center gap-2">
                    <svg class="w-8 h-8 text-shop-primary dark:text-blue-400" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                    </svg>
                    <span class="text-xl font-bold text-shop-primary dark:text-blue-400">SegmentCommerce</span>
                </a>

                <!-- Search Bar -->
                <div class="hidden md:block flex-1 max-w-md mx-4" x-data="searchComponent()">
                    <div class="relative">
                        <input type="search"
                               x-model="query"
                               @@input.debounce.300ms="search"
                               @@keydown.enter="goToSearch"
                               @@focus="showResults = query.length >= 2"
                               @@blur.debounce.200ms="showResults = false"
                               placeholder="Search products..."
                               class="w-full px-4 py-2 pl-10 pr-4 text-sm bg-gray-100 dark:bg-gray-800 border border-transparent rounded-lg focus:border-shop-primary dark:focus:border-blue-400 focus:outline-none focus:ring-2 focus:ring-shop-primary/20 dark:focus:ring-blue-400/20 transition-all" />
                        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                        
                        <!-- Loading indicator -->
                        <template x-if="loading">
                            <div class="absolute right-3 top-1/2 -translate-y-1/2">
                                <svg class="animate-spin w-4 h-4 text-shop-primary" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
                                </svg>
                            </div>
                        </template>
                        
                        <!-- Search Results Dropdown -->
                        <div x-show="showResults && results.length > 0"
                             x-cloak
                             x-transition:enter="transition ease-out duration-150"
                             x-transition:enter-start="opacity-0 transform -translate-y-2"
                             x-transition:enter-end="opacity-100 transform translate-y-0"
                             x-transition:leave="transition ease-in duration-100"
                             x-transition:leave-start="opacity-100"
                             x-transition:leave-end="opacity-0"
                             class="absolute top-full mt-2 w-full bg-white dark:bg-gray-800 rounded-lg shadow-xl border border-gray-200 dark:border-gray-700 max-h-96 overflow-auto z-50">
                            <template x-for="item in results.slice(0, 6)" :key="item.productId">
                                <a :href="'/products/' + item.productId"
                                   class="flex items-center gap-3 p-3 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                                    <img :src="item.imageUrl" :alt="item.name" class="w-12 h-12 object-cover rounded" />
                                    <div class="flex-1 min-w-0">
                                        <p class="text-sm font-medium text-gray-900 dark:text-white truncate" x-text="item.name"></p>
                                        <p class="text-xs text-gray-500 dark:text-gray-400" x-text="item.category"></p>
                                    </div>
                                    <span class="text-sm font-bold text-shop-primary" x-text="'$' + item.price.toFixed(2)"></span>
                                </a>
                            </template>
                            <template x-if="results.length > 6">
                                <a :href="'/products/search?q=' + encodeURIComponent(query)"
                                   class="block p-3 text-center text-sm text-shop-primary hover:bg-gray-50 dark:hover:bg-gray-700 font-medium">
                                    See all <span x-text="results.length"></span> results
                                </a>
                            </template>
                        </div>
                        
                        <!-- No results -->
                        <div x-show="showResults && query.length >= 2 && !loading && results.length === 0"
                             x-cloak
                             class="absolute top-full mt-2 w-full bg-white dark:bg-gray-800 rounded-lg shadow-xl border border-gray-200 dark:border-gray-700 p-4 text-center z-50">
                            <p class="text-sm text-gray-500 dark:text-gray-400">No products found for "<span x-text="query"></span>"</p>
                        </div>
                    </div>
                </div>

                <!-- Navigation -->
                <div class="hidden lg:flex items-center gap-6">
                    <a href="/" preload="mousedown" class="hover:text-shop-primary dark:hover:text-blue-400 transition-colors">Home</a>
                    <a href="/products" preload="mousedown" class="hover:text-shop-primary dark:hover:text-blue-400 transition-colors">Products</a>
                    
                    <!-- Categories Dropdown -->
                    <div class="relative" x-data="{ open: false }">
                        <button @@click="open = !open" 
                                @@click.outside="open = false"
                                class="flex items-center gap-1 hover:text-shop-primary dark:hover:text-blue-400 transition-colors">
                            Categories
                            <svg class="w-4 h-4 transition-transform" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>
                        <div x-show="open"
                             x-cloak
                             x-transition:enter="transition ease-out duration-150"
                             x-transition:enter-start="opacity-0 transform -translate-y-2"
                             x-transition:enter-end="opacity-100 transform translate-y-0"
                             x-transition:leave="transition ease-in duration-100"
                             x-transition:leave-start="opacity-100"
                             x-transition:leave-end="opacity-0"
                             class="absolute top-full left-0 mt-2 w-48 bg-white dark:bg-gray-800 rounded-lg shadow-xl border border-gray-200 dark:border-gray-700 py-2 z-50">
                            <a href="/products/category/tech" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                <span class="mr-2">💻</span> Tech
                            </a>
                            <a href="/products/category/fashion" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                <span class="mr-2">👗</span> Fashion
                            </a>
                            <a href="/products/category/home" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                <span class="mr-2">🏠</span> Home
                            </a>
                            <a href="/products/category/food" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                <span class="mr-2">🍳</span> Food
                            </a>
                            <a href="/products/category/sport" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                <span class="mr-2">⚽</span> Sport
                            </a>
                            <a href="/products/category/books" class="block px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                <span class="mr-2">📚</span> Books
                            </a>
                        </div>
                    </div>
                    
                    <a href="/segments" preload="mousedown" class="hover:text-shop-primary dark:hover:text-blue-400 transition-colors">Segments</a>
                </div>

                <!-- Right side actions -->
                <div class="flex items-center gap-3">
                    <!-- Tracking Mode Indicator -->
                    <partial name="Partials/_TrackingIndicator" />
                    
                    <!-- Dark mode toggle -->
                    <button @@click="darkMode = !darkMode" 
                            class="theme-toggle"
                            :title="darkMode ? 'Switch to light mode' : 'Switch to dark mode'">
                        <template x-if="!darkMode">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                            </svg>
                        </template>
                        <template x-if="darkMode">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                            </svg>
                        </template>
                    </button>

                    <!-- Interest signature toggle -->
                    <button x-data="{ showSignature: false }" 
                            @@click="$dispatch('toggle-signature')"
                            class="theme-toggle relative"
                            title="View your interest signature">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                  d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                        </svg>
                    </button>

                    <!-- Cart -->
                    <a href="/cart" class="theme-toggle relative" id="cart-icon">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                  d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                        </svg>
                        <span id="cart-count" class="cart-badge hidden">0</span>
                    </a>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main content -->
    <main id="main-content" class="container mx-auto px-4 py-8">
        @RenderBody()
    </main>

    <!-- Interest Signature Panel -->
    <div x-data="{ show: false }" 
         x-show="show" 
         x-cloak
         @@toggle-signature.window="show = !show"
         @@keydown.escape.window="show = false"
         class="interest-signature-panel animate-slide-up">
        <partial name="Partials/_InterestSignature" model="(ViewData.Model as HomeViewModel)?.InterestSignature" />
    </div>

    <!-- Footer -->
    <footer class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 mt-auto">
        <div class="container mx-auto px-4 py-6">
            <div class="flex flex-col md:flex-row items-center justify-between gap-4">
                <p class="text-sm text-gray-600 dark:text-gray-400">
                    SegmentCommerce - Zero PII Customer Intelligence Demo
                </p>
                <div class="flex items-center gap-4 text-sm text-gray-600 dark:text-gray-400">
                    <a href="#" class="hover:text-shop-primary dark:hover:text-blue-400">Privacy</a>
                    <a href="#" class="hover:text-shop-primary dark:hover:text-blue-400">About</a>
                    <a href="#" class="hover:text-shop-primary dark:hover:text-blue-400">How It Works</a>
                    <a href="/Admin" class="hover:text-shop-primary dark:hover:text-blue-400">Admin</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Fingerprinting is now handled by tracking-manager.js -->
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
