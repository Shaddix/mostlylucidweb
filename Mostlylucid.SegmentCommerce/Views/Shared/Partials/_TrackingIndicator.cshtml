@* 
    Tracking Mode Indicator & Switcher
    Shows current tracking mode with dropdown to change it.
    Integrates with TrackingManager.js for client-side state.
*@

<div x-data="{ open: false }" class="relative" @@click.away="open = false" @@keydown.escape.window="open = false">
    <!-- Indicator Button -->
    <button 
        @@click="open = !open"
        class="flex items-center gap-1.5 px-2 py-1 rounded-md text-xs font-medium transition-all duration-200
               hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
        :class="{
            'text-gray-600 dark:text-gray-400': trackingMode === 'none',
            'text-blue-600 dark:text-blue-400': trackingMode === 'fingerprint',
            'text-yellow-600 dark:text-yellow-400': trackingMode === 'cookie',
            'text-green-600 dark:text-green-400': trackingMode === 'identity'
        }"
        :title="modeInfo.description">
        
        <!-- Mode Icon -->
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" :d="modeIcon"/>
        </svg>
        
        <!-- Mode Label (hidden on mobile) -->
        <span class="hidden sm:inline" x-text="modeInfo.shortName"></span>
        
        <!-- Status Dot -->
        <span class="w-2 h-2 rounded-full" :class="modeColor"></span>
        
        <!-- Dropdown Arrow -->
        <svg class="w-3 h-3 transition-transform" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
    </button>
    
    <!-- Dropdown Panel -->
    <div 
        x-show="open"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 scale-95"
        x-transition:enter-end="opacity-100 scale-100"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100 scale-100"
        x-transition:leave-end="opacity-0 scale-95"
        class="absolute right-0 mt-2 w-80 bg-white dark:bg-gray-800 rounded-lg shadow-xl border border-gray-200 dark:border-gray-700 z-50 overflow-hidden"
        x-cloak>
        
        <!-- Header -->
        <div class="px-4 py-3 bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Tracking Mode</h3>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Choose how your activity is tracked</p>
        </div>
        
        <!-- Current Mode Info -->
        <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-700">
            <div class="flex items-start gap-3">
                <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center" :class="modeColor.replace('bg-', 'bg-opacity-20 text-')">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" :d="modeIcon"/>
                    </svg>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900 dark:text-white" x-text="modeInfo.name"></p>
                    <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5" x-text="modeInfo.privacy"></p>
                </div>
            </div>
        </div>
        
        <!-- Demo User Login (if in identity mode) -->
        <template x-if="isLoggedIn">
            <div class="px-4 py-3 bg-green-50 dark:bg-green-900/20 border-b border-gray-200 dark:border-gray-700">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-full bg-green-500 flex items-center justify-center text-white text-sm font-bold"
                             x-text="demoUser?.name?.charAt(0) || 'U'"></div>
                        <div>
                            <p class="text-sm font-medium text-gray-900 dark:text-white" x-text="demoUser?.name || 'Demo User'"></p>
                            <p class="text-xs text-gray-500 dark:text-gray-400" x-text="demoUser?.persona || 'Demo Profile'"></p>
                        </div>
                    </div>
                    <button 
                        @@click="logoutDemoUser()"
                        class="text-xs text-red-600 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 font-medium">
                        Log out
                    </button>
                </div>
            </div>
        </template>
        
        <!-- Mode Options -->
        <div class="py-2">
            <p class="px-4 py-1 text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Switch Mode</p>
            
            <!-- Session Only -->
            <button 
                @@click="setTrackingMode('none'); open = false"
                class="w-full px-4 py-2 flex items-center gap-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors"
                :class="{ 'bg-gray-100 dark:bg-gray-700': trackingMode === 'none' }">
                <div class="w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-gray-600 dark:text-gray-400">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div class="flex-1 text-left">
                    <p class="text-sm font-medium text-gray-900 dark:text-white">Session Only</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">Maximum privacy, no persistence</p>
                </div>
                <template x-if="trackingMode === 'none'">
                    <svg class="w-4 h-4 text-gray-600 dark:text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                </template>
            </button>
            
            <!-- Fingerprint -->
            <button 
                @@click="setTrackingMode('fingerprint'); open = false"
                class="w-full px-4 py-2 flex items-center gap-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors"
                :class="{ 'bg-blue-50 dark:bg-blue-900/20': trackingMode === 'fingerprint' }">
                <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-blue-600 dark:text-blue-400">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4"/>
                    </svg>
                </div>
                <div class="flex-1 text-left">
                    <p class="text-sm font-medium text-gray-900 dark:text-white">Device Fingerprint</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">No cookies, privacy-respecting</p>
                </div>
                <template x-if="trackingMode === 'fingerprint'">
                    <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                </template>
            </button>
            
            <!-- Cookie -->
            <button 
                @@click="setTrackingMode('cookie'); open = false"
                class="w-full px-4 py-2 flex items-center gap-3 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors"
                :class="{ 'bg-yellow-50 dark:bg-yellow-900/20': trackingMode === 'cookie' }">
                <div class="w-8 h-8 rounded-full bg-yellow-100 dark:bg-yellow-900/30 flex items-center justify-center text-yellow-600 dark:text-yellow-500">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                    </svg>
                </div>
                <div class="flex-1 text-left">
                    <p class="text-sm font-medium text-gray-900 dark:text-white">Cookie Tracking</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">Standard web tracking</p>
                </div>
                <template x-if="trackingMode === 'cookie'">
                    <svg class="w-4 h-4 text-yellow-600 dark:text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                </template>
            </button>
        </div>
        
        <!-- Demo Users Section -->
        <div class="border-t border-gray-200 dark:border-gray-700 py-2">
            <p class="px-4 py-1 text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Demo Profiles</p>
            <p class="px-4 py-1 text-xs text-gray-500 dark:text-gray-400">Try pre-built customer personas</p>
            
            <!-- Demo User Buttons - loaded from server when dropdown opens -->
            <!-- hx-boost=false prevents HTMX from hijacking child button clicks -->
            <div class="px-4 py-2 space-y-2" 
                 hx-get="/api/demo-users" 
                 hx-trigger="intersect once"
                 hx-target="this"
                 hx-swap="innerHTML"
                 hx-push-url="false"
                 hx-boost="false">
                <div class="animate-pulse flex items-center gap-2">
                    <div class="w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-700"></div>
                    <div class="flex-1">
                        <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded w-24 mb-1"></div>
                        <div class="h-2 bg-gray-200 dark:bg-gray-700 rounded w-32"></div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Privacy Info -->
        <div class="border-t border-gray-200 dark:border-gray-700 px-4 py-3 bg-gray-50 dark:bg-gray-900">
            <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-gray-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div class="text-xs text-gray-500 dark:text-gray-400">
                    <p class="font-medium text-gray-700 dark:text-gray-300">Zero PII Policy</p>
                    <p class="mt-0.5">We never store personal data. All tracking is behavioral and anonymous.</p>
                </div>
            </div>
            
            <!-- Browser Detection Info -->
            <template x-if="privacyFeatures?.isFirefox || privacyFeatures?.isBrave">
                <div class="mt-2 flex items-start gap-2 p-2 bg-blue-50 dark:bg-blue-900/20 rounded">
                    <svg class="w-4 h-4 text-blue-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                    </svg>
                    <p class="text-xs text-blue-700 dark:text-blue-300">
                        <span x-text="privacyFeatures?.isFirefox ? 'Firefox' : 'Brave'"></span> detected. 
                        Using privacy-respecting fingerprint mode.
                    </p>
                </div>
            </template>
            
            <!-- Reset Button -->
            <button 
                @@click="resetTracking(); open = false"
                class="mt-2 w-full text-center text-xs text-red-600 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 font-medium py-1">
                Reset All Tracking Data
            </button>
        </div>
    </div>
</div>
