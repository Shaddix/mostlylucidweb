@model Cart

<div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6">
    <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Your Cart</h2>
    
    @if (Model.Items.Any())
    {
        <div class="divide-y divide-gray-200 dark:divide-gray-700">
            @foreach (var item in Model.Items)
            {
                var imageUrl = item.Product.ImageUrl;
                if (string.IsNullOrEmpty(imageUrl) || imageUrl.Contains("placeholder"))
                {
                    imageUrl = $"/api/placeholder/{Uri.EscapeDataString(item.Product.Category)}/{Uri.EscapeDataString(item.Product.Name)}?w=64&h=64";
                }
                <div class="py-4 flex items-center gap-4">
                    <!-- Product Image -->
                    <img src="@imageUrl" 
                         alt="@item.Product.Name"
                         class="w-16 h-16 object-cover rounded-lg" />
                    
                    <!-- Product Details -->
                    <div class="flex-1 min-w-0">
                        <h3 class="font-medium text-gray-900 dark:text-white truncate">
                            @item.Product.Name
                        </h3>
                        <p class="text-sm text-gray-500 dark:text-gray-400">
                            £@item.Product.Price.ToString("0.00") each
                        </p>
                    </div>
                    
                    <!-- Quantity Controls -->
                    <div class="flex items-center gap-2">
                        <button class="p-1 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700"
                                hx-post="/cart/decrease/@item.Product.Id"
                                hx-target="#cart-container"
                                hx-swap="innerHTML">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
                            </svg>
                        </button>
                        
                        <span class="w-8 text-center font-medium">@item.Quantity</span>
                        
                        <button class="p-1 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700"
                                hx-post="/cart/increase/@item.Product.Id"
                                hx-target="#cart-container"
                                hx-swap="innerHTML">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                            </svg>
                        </button>
                    </div>
                    
                    <!-- Remove Button -->
                    <button class="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-full"
                            hx-post="/cart/remove/@item.Product.Id"
                            hx-target="#cart-container"
                            hx-swap="innerHTML">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                    </button>
                </div>
            }
        </div>
        
        <!-- Cart Total -->
        <div class="mt-6 pt-4 border-t border-gray-200 dark:border-gray-700">
            <div class="flex items-center justify-between mb-4">
                <span class="text-lg font-medium text-gray-900 dark:text-white">Total</span>
                <span class="text-2xl font-bold text-shop-primary dark:text-blue-400">
                    £@Model.Total.ToString("0.00")
                </span>
            </div>
            
            <button class="w-full btn-primary py-3 text-lg">
                Proceed to Checkout
            </button>
        </div>
    }
    else
    {
        <div class="text-center py-8">
            <svg class="w-16 h-16 mx-auto text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                      d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            <p class="text-gray-500 dark:text-gray-400 mb-4">Your cart is empty</p>
            <a href="/products" class="btn-secondary inline-block">Browse Products</a>
        </div>
    }
</div>
