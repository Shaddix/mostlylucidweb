@using Mostlylucid.SegmentCommerce.Controllers.Api
@using Mostlylucid.SegmentCommerce.Services
@model RecommendationsViewModel

@{
    var layoutClass = Model.Layout switch
    {
        "grid" => "grid grid-cols-2 md:grid-cols-4 gap-4",
        "horizontal" => "flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory",
        _ => "flex gap-4 overflow-x-auto pb-4" // carousel (default)
    };
    
    var itemClass = Model.Layout switch
    {
        "grid" => "",
        "horizontal" => "w-56 flex-shrink-0 snap-start",
        _ => "w-72 flex-shrink-0" // carousel
    };
}

@if (Model.Products.Any())
{
    <section class="mb-8">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">@Model.Title</h2>
            @if (Model.Products.Count > 4)
            {
                <span class="text-sm text-gray-500 dark:text-gray-400">
                    @Model.Products.Count products
                </span>
            }
        </div>
        
        <div class="relative">
            <div class="@layoutClass">
                @foreach (var product in Model.Products)
                {
                    <div class="@itemClass">
                        <div class="product-card bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden relative h-full"
                             data-product-id="@product.Id">
                            
                            @* Recommendation badge *@
                            @{
                                string badgeClass;
                                string badgeText;
                                string badgeIcon;
                                switch (product.RecommendationType)
                                {
                                    case "interest":
                                        badgeClass = "bg-blue-500";
                                        badgeText = "For You";
                                        badgeIcon = "star";
                                        break;
                                    case "brand":
                                        badgeClass = "bg-purple-500";
                                        badgeText = product.Brand ?? "Brand Pick";
                                        badgeIcon = "tag";
                                        break;
                                    case "deal":
                                        badgeClass = "bg-green-500";
                                        badgeText = "Great Deal";
                                        badgeIcon = "percent";
                                        break;
                                    case "trending":
                                        badgeClass = "bg-orange-500";
                                        badgeText = "Trending";
                                        badgeIcon = "fire";
                                        break;
                                    case "similar":
                                        badgeClass = "bg-indigo-500";
                                        badgeText = "Similar";
                                        badgeIcon = "sparkles";
                                        break;
                                    case "cross_sell":
                                        badgeClass = "bg-pink-500";
                                        badgeText = "Pairs Well";
                                        badgeIcon = "puzzle";
                                        break;
                                    case "session_interest":
                                        badgeClass = "bg-blue-400";
                                        badgeText = "Recent Interest";
                                        badgeIcon = "clock";
                                        break;
                                    default:
                                        badgeClass = "bg-gray-500";
                                        badgeText = "Suggested";
                                        badgeIcon = "lightbulb";
                                        break;
                                }
                            }
                            
                            <span class="absolute top-2 left-2 z-10 px-2 py-1 text-xs font-medium text-white rounded-full @badgeClass flex items-center gap-1">
                                @switch (badgeIcon)
                                {
                                    case "star":
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                        </svg>
                                        break;
                                    case "tag":
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                                        </svg>
                                        break;
                                    case "percent":
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                        break;
                                    case "fire":
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"/>
                                        </svg>
                                        break;
                                    case "sparkles":
                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 17.5 9.134a1 1 0 010 1.732l-3.354 1.935-1.18 4.455a1 1 0 01-1.933 0L9.854 12.8 6.5 10.866a1 1 0 010-1.732l3.354-1.935 1.18-4.455A1 1 0 0112 2z" clip-rule="evenodd"/>
                                        </svg>
                                        break;
                                    case "puzzle":
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/>
                                        </svg>
                                        break;
                                    case "clock":
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                        break;
                                    default:
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                                        </svg>
                                        break;
                                }
                                @badgeText
                            </span>
                            
                            @* Sale badge *@
                            @if (product.IsOnSale)
                            {
                                var discount = Math.Round((1 - (double)product.Price / (double)(product.OriginalPrice ?? product.Price)) * 100);
                                <span class="absolute top-2 right-2 z-10 px-2 py-1 text-xs font-bold text-white bg-red-500 rounded-full">
                                    -@discount%
                                </span>
                            }
                            
                            @* Product Image - Clickable *@
                            @{
                                var imageUrl = product.ImageUrl;
                                if (string.IsNullOrEmpty(imageUrl) || imageUrl.Contains("placeholder"))
                                {
                                    imageUrl = $"/api/placeholder/{Uri.EscapeDataString(product.Category)}/{Uri.EscapeDataString(product.Name)}?w=288&h=160";
                                }
                            }
                            <a href="/products/details/@product.Id" class="block aspect-w-1 aspect-h-1 bg-gray-100 dark:bg-gray-700 hover:opacity-90 transition-opacity">
                                <img src="@imageUrl" 
                                     alt="@product.Name"
                                     class="object-cover w-full h-40"
                                     loading="lazy" />
                            </a>
                            
                            @* Product Details *@
                            <div class="p-4 flex flex-col flex-grow">
                                <a href="/products/category/@product.Category" class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-1 hover:text-shop-primary dark:hover:text-blue-400 transition-colors">
                                    @product.Category
                                </a>
                                
                                <h3 class="font-semibold text-gray-900 dark:text-white mb-2 line-clamp-2 text-sm">
                                    <a href="/products/details/@product.Id" class="hover:text-shop-primary dark:hover:text-blue-400 transition-colors">
                                        @product.Name
                                    </a>
                                </h3>
                                
                                @* Recommendation reason *@
                                @if (Model.ShowReasons && !string.IsNullOrEmpty(product.RecommendationReason))
                                {
                                    <p class="text-xs text-gray-500 dark:text-gray-400 italic mb-2 line-clamp-1">
                                        @product.RecommendationReason
                                    </p>
                                }
                                
                                @* Price *@
                                <div class="flex items-center gap-2 mb-3 mt-auto">
                                    <span class="text-lg font-bold text-shop-primary">
                                        @product.Price.ToString("C")
                                    </span>
                                    @if (product.OriginalPrice.HasValue && product.OriginalPrice > product.Price)
                                    {
                                        <span class="text-sm text-gray-400 line-through">
                                            @product.OriginalPrice.Value.ToString("C")
                                        </span>
                                    }
                                </div>
                                
                                @* Tags (show max 2 for space) *@
                                @if (product.Tags.Any())
                                {
                                    <div class="flex flex-wrap gap-1 mb-3">
                                        @foreach (var tag in product.Tags.Take(2))
                                        {
                                            <span class="text-xs px-2 py-0.5 bg-gray-100 dark:bg-gray-700 rounded-full text-gray-600 dark:text-gray-300">
                                                @tag
                                            </span>
                                        }
                                    </div>
                                }
                                
                                @* Add to Cart Button *@
                                <button class="w-full btn-primary text-sm py-2"
                                        hx-post="/cart/add/@product.Id"
                                        hx-target="#cart-count"
                                        hx-swap="outerHTML">
                                    Add to Cart
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
            
            @* Scroll navigation for carousel layouts *@
            @if (Model.Layout is "carousel" or "horizontal" && Model.Products.Count > 4)
            {
                <div class="hidden md:flex absolute right-0 top-1/2 -translate-y-1/2 gap-2">
                    <button class="p-2 bg-white dark:bg-gray-800 rounded-full shadow-md hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                            onclick="this.closest('.relative').querySelector('[class*=overflow-x-auto]').scrollBy({left: -300, behavior: 'smooth'})">
                        <svg class="w-5 h-5 text-gray-600 dark:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                        </svg>
                    </button>
                    <button class="p-2 bg-white dark:bg-gray-800 rounded-full shadow-md hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                            onclick="this.closest('.relative').querySelector('[class*=overflow-x-auto]').scrollBy({left: 300, behavior: 'smooth'})">
                        <svg class="w-5 h-5 text-gray-600 dark:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </button>
                </div>
            }
        </div>
        
        @* Relevance score indicator (subtle, for transparency) *@
        @if (Model.ShowReasons)
        {
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-2">
                Recommendations based on your browsing preferences
            </p>
        }
    </section>
}
else
{
    @* Empty state *@
    <section class="mb-8 text-center py-8">
        <p class="text-gray-500 dark:text-gray-400">
            No recommendations available yet. Browse some products to get personalized suggestions!
        </p>
    </section>
}
