@model Product

<div class="product-card bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden relative"
     data-product-id="@Model.Id">
    
    @if (Model.IsRecommended)
    {
        <span class="badge-recommended">Recommended</span>
    }
    else if (Model.IsTrending)
    {
        <span class="badge-trending">Trending</span>
    }
    
    @if (Model.OriginalPrice.HasValue && Model.OriginalPrice > Model.Price)
    {
        var discount = (int)Math.Round((1 - Model.Price / Model.OriginalPrice.Value) * 100);
        <span class="absolute top-2 right-2 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded z-10">
            -@discount%
        </span>
    }
    
    <!-- Product Image - Clickable -->
    @{
        var imageUrl = Model.ImageUrl;
        if (string.IsNullOrEmpty(imageUrl) || imageUrl.Contains("placeholder"))
        {
            imageUrl = $"/api/placeholder/{Uri.EscapeDataString(Model.Category)}/{Uri.EscapeDataString(Model.Name)}?w=400&h=192";
        }
    }
    <a href="/products/details/@Model.Id" class="block aspect-w-1 aspect-h-1 bg-gray-100 dark:bg-gray-700 cursor-pointer hover:opacity-90 transition-opacity">
        <img src="@imageUrl" 
             alt="@Model.Name"
             class="object-cover w-full h-48"
             loading="lazy" />
    </a>
    
    <!-- Product Details -->
    <div class="p-4">
        <!-- Category -->
        <a href="/products/category/@Model.Category" class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wide hover:text-shop-primary dark:hover:text-blue-400 transition-colors">
            @Model.Category
        </a>
        
        <!-- Seller Info -->
        @if (Model.Seller != null)
        {
            <div class="flex items-center gap-2 mt-1 mb-2">
                @{
                    var sellerLogo = Model.Seller.LogoUrl;
                    if (string.IsNullOrEmpty(sellerLogo))
                    {
                        // Generate a placeholder with seller's initials
                        sellerLogo = $"/api/placeholder/seller/{Uri.EscapeDataString(Model.Seller.Name)}?w=24&h=24";
                    }
                }
                <img src="@sellerLogo" 
                     alt="@Model.Seller.Name"
                     class="w-5 h-5 rounded-full object-cover border border-gray-200 dark:border-gray-600" />
                <span class="text-xs text-gray-500 dark:text-gray-400 truncate max-w-[120px]" title="@Model.Seller.Name">
                    @Model.Seller.Name
                </span>
                @if (Model.Seller.IsVerified)
                {
                    <svg class="w-3 h-3 text-blue-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" title="Verified Seller">
                        <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                }
            </div>
        }
        
        <h3 class="font-semibold text-gray-900 dark:text-white mb-2 line-clamp-2">
            <a href="/products/details/@Model.Id" class="hover:text-shop-primary dark:hover:text-blue-400 transition-colors">
                @Model.Name
            </a>
        </h3>
        
        <p class="text-sm text-gray-600 dark:text-gray-300 mb-3 line-clamp-2">
            @Model.Description
        </p>
        
        <!-- Price -->
        <div class="flex items-center gap-2 mb-3">
            <span class="price">£@Model.Price.ToString("0.00")</span>
            @if (Model.OriginalPrice.HasValue && Model.OriginalPrice > Model.Price)
            {
                <span class="price-original">£@Model.OriginalPrice.Value.ToString("0.00")</span>
            }
        </div>
        
        <!-- Tags -->
        @if (Model.Tags.Any())
        {
            <div class="flex flex-wrap gap-1 mb-3">
                @foreach (var tag in Model.Tags.Take(3))
                {
                    <span class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-700 rounded-full text-gray-600 dark:text-gray-300">
                        @tag
                    </span>
                }
            </div>
        }
        
        <!-- Add to Cart -->
        <button class="w-full btn-primary"
                hx-post="/cart/add/@Model.Id"
                hx-target="#cart-count"
                hx-swap="outerHTML">
            Add to Cart
        </button>
    </div>
</div>
