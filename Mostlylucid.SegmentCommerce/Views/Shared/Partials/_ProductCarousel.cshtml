@model (string Title, IEnumerable<Product> Products)

<section class="mb-8">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">@Model.Title</h2>
    
    <div class="relative">
        <!-- Carousel Container -->
        <div class="carousel-container flex gap-4 pb-4" 
             x-data="{ scrollContainer: null }"
             x-init="scrollContainer = $el">
            @foreach (var product in Model.Products)
            {
                <div class="carousel-item w-72 flex-shrink-0">
                    <partial name="Partials/_ProductCard" model="product" />
                </div>
            }
        </div>
        
        <!-- Scroll indicators (optional, shows on larger screens) -->
        <div class="hidden md:flex absolute right-0 top-1/2 -translate-y-1/2 gap-2">
            <button class="p-2 bg-white dark:bg-gray-800 rounded-full shadow-md hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                    onclick="this.closest('.relative').querySelector('.carousel-container').scrollBy({left: -300, behavior: 'smooth'})">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </button>
            <button class="p-2 bg-white dark:bg-gray-800 rounded-full shadow-md hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                    onclick="this.closest('.relative').querySelector('.carousel-container').scrollBy({left: 300, behavior: 'smooth'})">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </button>
        </div>
    </div>
</section>
