@model InterestSignature?

@{
    var signature = Model ?? new InterestSignature();
    var hasInterests = signature.Interests.Any();
}

<div class="space-y-4">
    <div class="flex items-center justify-between">
        <h3 class="font-semibold text-gray-900 dark:text-white">Your Interest Signature</h3>
        <button @@click="$dispatch('toggle-signature')" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
    </div>
    
    <p class="text-sm text-gray-600 dark:text-gray-400">
        This shows what we've learned about your interests. All data stays in your browser - we don't store it on our servers.
    </p>
    
    @if (hasInterests)
    {
        <div class="space-y-3">
            @foreach (var interest in signature.Interests.OrderByDescending(i => i.Value.EffectiveWeight))
            {
                var category = interest.Key;
                var weight = interest.Value;
                var displayName = InterestCategories.DisplayNames.GetValueOrDefault(category, category);
                var cssClass = InterestCategories.CssClasses.GetValueOrDefault(category, "bg-gray-400");
                var percentage = (int)(weight.EffectiveWeight * 100);
                
                <div class="space-y-1">
                    <div class="flex items-center justify-between text-sm">
                        <span class="font-medium text-gray-700 dark:text-gray-300">@displayName</span>
                        <span class="text-gray-500 dark:text-gray-400">
                            @percentage%
                            @if (weight.IsDecaying)
                            {
                                <span class="text-amber-500 text-xs ml-1" title="Decaying - browse this category to reinforce">
                                    (fading)
                                </span>
                            }
                        </span>
                    </div>
                    <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                        <div class="interest-bar @cssClass" 
                             style="width: @(percentage)%"
                             data-decaying="@weight.IsDecaying.ToString().ToLower()">
                        </div>
                    </div>
                </div>
            }
        </div>
        
        <!-- Actions -->
        <div class="pt-4 border-t border-gray-200 dark:border-gray-700 space-y-2">
            <button class="w-full text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white py-2 rounded border border-gray-300 dark:border-gray-600 hover:border-gray-400 dark:hover:border-gray-500 transition-colors"
                    hx-post="/api/signature/reset"
                    hx-target="closest .interest-signature-panel"
                    hx-swap="innerHTML">
                Clear My Interests
            </button>
            
            @if (!signature.IsPersistent)
            {
                <button class="w-full text-sm bg-shop-secondary text-white py-2 rounded hover:bg-teal-600 transition-colors"
                        hx-post="/api/signature/persist"
                        hx-target="closest .interest-signature-panel"
                        hx-swap="innerHTML">
                    Save Across Sessions
                </button>
            }
        </div>
    }
    else
    {
        <div class="text-center py-6">
            <svg class="w-12 h-12 mx-auto text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                      d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
            <p class="text-sm text-gray-500 dark:text-gray-400">
                No interests recorded yet. Browse some products to build your signature!
            </p>
        </div>
    }
    
    <!-- Transparency notice -->
    <div class="mt-4 p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
        <p class="text-xs text-blue-700 dark:text-blue-300">
            <strong>Transparency:</strong> We use your browsing behaviour to show relevant products.
            Your data never leaves your device unless you explicitly choose to save it.
        </p>
    </div>
</div>
