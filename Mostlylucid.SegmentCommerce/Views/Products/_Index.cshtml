@model List<Product>
@{
    Layout = null;
    var currentCategory = ViewData["CurrentCategory"] as string;
    var categories = ViewData["Categories"] as IEnumerable<string> ?? [];
    var searchQuery = ViewData["SearchQuery"] as string;
    
    var title = string.IsNullOrEmpty(currentCategory) 
        ? (string.IsNullOrEmpty(searchQuery) ? "All Products" : $"Search: {searchQuery}")
        : InterestCategories.DisplayNames.GetValueOrDefault(currentCategory, currentCategory);
}

<div class="flex flex-col lg:flex-row gap-8">
    <!-- Sidebar -->
    <aside class="lg:w-64 flex-shrink-0">
        <div class="sticky top-24 bg-white dark:bg-gray-800 rounded-lg shadow p-4">
            <h3 class="font-semibold text-gray-900 dark:text-white mb-4">Categories</h3>
            <nav class="space-y-2">
                <a href="/products" 
                   class="block px-3 py-2 rounded @(string.IsNullOrEmpty(currentCategory) ? "bg-shop-primary text-white" : "hover:bg-gray-100 dark:hover:bg-gray-700")">
                    All Products
                </a>
                @foreach (var category in categories)
                {
                    var displayName = InterestCategories.DisplayNames.GetValueOrDefault(category, category);
                    var isActive = currentCategory == category;
                    
                    <a href="/products/category/@category" 
                       class="block px-3 py-2 rounded @(isActive ? "bg-shop-primary text-white" : "hover:bg-gray-100 dark:hover:bg-gray-700")">
                        @displayName
                    </a>
                }
            </nav>
            
            <!-- Search -->
            <div class="mt-6 pt-4 border-t border-gray-200 dark:border-gray-700">
                <form action="/products/search" method="get" class="flex gap-2">
                    <input type="text" 
                           name="q" 
                           value="@searchQuery"
                           placeholder="Search..."
                           class="flex-1 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                    <button type="submit" class="btn-primary px-3">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                    </button>
                </form>
            </div>
        </div>
    </aside>
    
    <!-- Main Content -->
    <main class="flex-1">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
                @title
            </h1>
            <span class="text-gray-600 dark:text-gray-400">
                @Model.Count product(s)
            </span>
        </div>
        
        <partial name="Partials/_ProductList" model="Model" />
    </main>
</div>
