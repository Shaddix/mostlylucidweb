<div class="field-display">
    <div class="field-header">
        <h2>@Field.Label</h2>
        @if (!Field.Required)
        {
            <span class="optional-badge">Optional</span>
        }
    </div>

    <div class="field-prompt">
        @Message
    </div>

    @if (FieldState != null)
    {
        <div class="field-status status-@FieldState.Status.ToString().ToLower()">
            @GetStatusText()
        </div>

        @if (FieldState.AttemptCount > 1)
        {
            <div class="attempt-count">
                Attempt @FieldState.AttemptCount
            </div>
        }
    }
</div>

<style>
    .field-display {
        padding: 1.5rem;
        background: #f8fafc;
        border-radius: 0.5rem;
        margin: 1rem 0;
    }

    .field-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .field-header h2 {
        margin: 0;
        font-size: 1.25rem;
    }

    .optional-badge {
        font-size: 0.75rem;
        padding: 0.125rem 0.5rem;
        background: #e2e8f0;
        border-radius: 999px;
        color: #64748b;
    }

    .field-prompt {
        font-size: 1.1rem;
        color: #334155;
        margin-bottom: 1rem;
    }

    .field-status {
        font-size: 0.875rem;
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
        display: inline-block;
    }

    .field-status.status-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .field-status.status-inprogress {
        background: #dbeafe;
        color: #1e40af;
    }

    .field-status.status-awaitingconfirmation {
        background: #fef9c3;
        color: #854d0e;
    }

    .field-status.status-confirmed {
        background: #dcfce7;
        color: #166534;
    }

    .attempt-count {
        font-size: 0.75rem;
        color: #94a3b8;
        margin-top: 0.5rem;
    }
</style>

@code {
    [Parameter, EditorRequired]
    public FieldDefinition Field { get; set; } = null!;

    [Parameter]
    public FieldState? FieldState { get; set; }

    [Parameter]
    public string? Message { get; set; }

    private string GetStatusText() => FieldState?.Status switch
    {
        Models.State.FieldStatus.Pending => "Waiting",
        Models.State.FieldStatus.InProgress => "Listening...",
        Models.State.FieldStatus.AwaitingConfirmation => "Please confirm",
        Models.State.FieldStatus.Confirmed => $"Confirmed: {FieldState.Value}",
        Models.State.FieldStatus.Skipped => "Skipped",
        _ => ""
    };
}
