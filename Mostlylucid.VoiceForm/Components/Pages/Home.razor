@page "/"
@inject IFormSchemaLoader SchemaLoader
@inject NavigationManager Navigation

<div class="top-bar">
    <h1>Voice Form Demo</h1>
    <button class="theme-toggle" onclick="voiceFormTheme.toggle()">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <span>Dark Mode</span>
    </button>
</div>

<main>
    <div class="home-container">
        <div class="hero-section">
            <div class="hero-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
                </svg>
            </div>
            <p class="hero-text">
                A <strong>Ten Commandments compliant</strong> voice-to-form system
            </p>
        </div>

        <div class="features-grid">
            <div class="feature-item">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                </div>
                <span>Speech as lossy input</span>
            </div>
            <div class="feature-item">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                </div>
                <span>LLM as translator</span>
            </div>
            <div class="feature-item">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
                    </svg>
                </div>
                <span>Deterministic state machine</span>
            </div>
            <div class="feature-item">
                <div class="feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
                    </svg>
                </div>
                <span>Fully local stack</span>
            </div>
        </div>

        <h2>Available Forms</h2>

        @if (_loading)
        {
            <div class="loading">Loading forms...</div>
        }
        else if (_formIds.Count == 0)
        {
            <div class="empty-state">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <p>No forms found</p>
                <span>Add JSON form files to <code>Data/SampleForms/</code></span>
            </div>
        }
        else
        {
            <div class="forms-list">
                @foreach (var formId in _formIds)
                {
                    <a href="/voiceform/@formId" class="form-card">
                        <div class="form-card-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                        </div>
                        <div class="form-card-content">
                            <h3>@FormatFormName(formId)</h3>
                            <p>Start filling out this form using voice</p>
                        </div>
                        <svg class="form-card-arrow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>
                }
            </div>
        }
    </div>
</main>

<style>
    .hero-section {
        text-align: center;
        padding: 2rem 0;
        margin-bottom: 2rem;
    }

    .hero-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 1rem;
        background: var(--accent-blue);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-icon svg {
        width: 40px;
        height: 40px;
        color: white;
    }

    .hero-text {
        font-size: 1.25rem;
        color: var(--text-secondary);
        margin: 0;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 3rem;
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 0.5rem;
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    .feature-icon {
        width: 36px;
        height: 36px;
        background: var(--bg-tertiary);
        border-radius: 0.375rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .feature-icon svg {
        width: 20px;
        height: 20px;
        color: var(--accent-blue);
    }

    h2 {
        font-size: 1.25rem;
        margin-bottom: 1rem;
        color: var(--text-primary);
    }

    .forms-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .form-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 0.75rem;
        text-decoration: none;
        transition: all 0.2s;
    }

    .form-card:hover {
        border-color: var(--accent-blue);
        box-shadow: 0 4px 12px var(--shadow);
        transform: translateY(-2px);
        text-decoration: none;
    }

    .form-card-icon {
        width: 48px;
        height: 48px;
        background: var(--bg-tertiary);
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .form-card-icon svg {
        width: 24px;
        height: 24px;
        color: var(--accent-blue);
    }

    .form-card-content {
        flex: 1;
    }

    .form-card-content h3 {
        margin: 0 0 0.25rem 0;
        color: var(--text-primary);
        font-size: 1.1rem;
    }

    .form-card-content p {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.875rem;
    }

    .form-card-arrow {
        width: 20px;
        height: 20px;
        color: var(--text-faint);
        transition: transform 0.2s;
    }

    .form-card:hover .form-card-arrow {
        transform: translateX(4px);
        color: var(--accent-blue);
    }

    .empty-state {
        text-align: center;
        padding: 3rem;
        background: var(--bg-secondary);
        border: 1px dashed var(--border-color);
        border-radius: 0.75rem;
    }

    .empty-state svg {
        width: 48px;
        height: 48px;
        color: var(--text-faint);
        margin-bottom: 1rem;
    }

    .empty-state p {
        margin: 0 0 0.5rem 0;
        font-weight: 500;
        color: var(--text-primary);
    }

    .empty-state span {
        font-size: 0.875rem;
        color: var(--text-muted);
    }
</style>

@code {
    private List<string> _formIds = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var ids = await SchemaLoader.GetFormIdsAsync();
        _formIds = ids.ToList();
        _loading = false;
    }

    private string FormatFormName(string formId)
    {
        // Convert kebab-case to Title Case
        return string.Join(" ", formId.Split('-')
            .Select(word => char.ToUpper(word[0]) + word.Substring(1)));
    }
}
