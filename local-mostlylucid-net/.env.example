# Docker Registry Environment Variables
# Copy this file to .env and configure with your actual values

# ============================================================================
# Registry Configuration
# ============================================================================

# Domain for the registry (must match your DNS and Cloudflare tunnel config)
REGISTRY_DOMAIN=docker.mostlylucid.net

# ============================================================================
# Authentication
# ============================================================================

# Username for registry access
REGISTRY_USERNAME=admin

# Password hash for registry access
# Generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
# Example below is for password: 'changeme' - CHANGE THIS!
REGISTRY_PASSWORD_HASH=$2a$14$Zkx19XLiW6VYouLHR5NmfOFU0z2GTNmpkT/5qqR7hx7wNVnaLJ.ou

# ============================================================================
# Cloudflare Tunnel
# ============================================================================

# Cloudflare tunnel token
# Get this from Cloudflare Zero Trust dashboard:
# 1. Go to https://one.dash.cloudflare.com/
# 2. Navigate to Networks > Tunnels
# 3. Create a new tunnel or select existing
# 4. Configure tunnel to point to http://caddy:80
# 5. Copy the tunnel token here
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# ============================================================================
# Watchtower Configuration (Optional)
# ============================================================================

# Enable Watchtower notifications (optional)
# Supported: email, slack, msteams, gotify
# Leave empty to disable
WATCHTOWER_NOTIFICATIONS=

# Notification URL (depends on notification type)
# Examples:
#   Email: smtp://username:password@host:port/?fromAddress=from@example.com&toAddresses=to@example.com
#   Slack: https://hooks.slack.com/services/YOUR/WEBHOOK/URL
#   Gotify: gotify://gotify-host/token
WATCHTOWER_NOTIFICATION_URL=

# Enable debug logging for Watchtower (true/false)
WATCHTOWER_DEBUG=false

# Enable trace logging for Watchtower (true/false)
WATCHTOWER_TRACE=false
