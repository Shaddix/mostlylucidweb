@using MarkdownBaseService = Mostlylucid.Services.Markdown.MarkdownBaseService
@model Mostlylucid.Models.Editor.EditorModel

<div class="min-h-screen flex flex-col bg-gray-100 dark:bg-gray-900"  x-data="{ currentLanguage: '' }"
     x-init="$nextTick(() =>{
         window.mostlylucid.simplemde.setupCodeEditor('markdowneditor');
         // Watch for language changes and clear translation results
         const langSelect = document.getElementById('languageSelect');
         if (langSelect) {
             langSelect.addEventListener('change', (e) => {
                 const newLang = e.target.value;
                 if (currentLanguage && currentLanguage !== newLang) {
                     // Language changed - clear previous translation results
                     const translationsDiv = document.getElementById('translations');
                     const translatedContent = document.getElementById('translatedcontent');
                     if (translationsDiv) {
                         translationsDiv.classList.add('hidden');
                         translationsDiv.innerHTML = '';
                     }
                     if (translatedContent) {
                         translatedContent.classList.add('hidden');
                         // Clear the SimpleMDE content if it exists
                         const mde = window.mostlylucid.simplemde.getinstance('translatedcontentarea');
                         if (mde) mde.value('');
                     }
                 }
                 currentLanguage = newLang;
             });
         }
     })">
    @if (!string.IsNullOrEmpty(Model.PostViewModel.Slug))
    {
    @if (Model.PostViewModel.Language != MarkdownBaseService.EnglishLanguage)
    {
    <a asp-action="Language" asp-controller="Blog" asp-route-slug="@Model.PostViewModel.Slug" asp-route-language="@Model.PostViewModel.Language" class="text-green-dark dark:text-green"><i class="bx bx-chevron-left"></i> Back to "@Model.PostViewModel.Title"</a>
    }
    else
    {
    <a asp-action="Show" asp-controller="Blog" asp-route-slug="@Model.PostViewModel.Slug" class="text-green-dark dark:text-green"><i class="bx bx-chevron-left"></i> Back to "@Model.PostViewModel.Title"</a>
    }
    }


    <p class="text-blue-dark dark:text-blue-light px-4 py-2">This is a viewer only at the moment <a asp-action="Show" asp-controller="Blog" asp-route-slug="markdownprevieweditor" class="text-green-dark dark:text-green"> see the article</a> on how this works.</p>
    <div class="container mx-auto p-2 flex-1 flex flex-col">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 flex-1">
            <!-- Column 1 - Editor -->
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg flex flex-col min-h-[600px]">
                <p class="text-blue-dark dark:text-blue-light text-sm px-4 py-2 border-b border-gray-200 dark:border-gray-700">To update the preview hit Ctrl-Alt-R (or ⌘-Alt-R on Mac) or Enter to refresh. The Save <i class="bx bx-save"></i> icon lets you save the markdown file to disk </p>
                <div class="flex-1 flex flex-col">
                    <textarea class="markdowneditor hidden" id="markdowneditor">@Model.Markdown</textarea>
                </div>
            </div>

            <!-- Column 2 - Preview -->
            <div class="bg-white dark:bg-gray-800 dark:text-white text-black rounded-lg shadow-lg flex flex-col min-h-[600px] overflow-hidden">
                <p class="text-blue-dark dark:text-blue-light text-sm px-4 py-2 border-b border-gray-200 dark:border-gray-700">This is a preview from the server running through my markdig pipeline</p>
                @if (Model.IsNew)
                {
                var translationHidden = Model.TranslationTasks.Any() ? "" : "hidden";

                <div class="flex items-center gap-3 px-4 py-2 border-b border-gray-200 dark:border-gray-700">
                    <partial name="_LanguageDropDown" for="Languages"/>
                    <button class="btn btn-primary btn-sm gap-1" x-on:click="window.mostlylucid.translations.submitTranslation">
                        <i class='bx bx-send'></i>Translate
                    </button>
                </div>
                <div id="translations" class="@translationHidden px-4 py-2">
                    <partial name="_GetTranslations" model="Model.TranslationTasks" />
                </div>
                <div id="translatedcontent" class="hidden px-4">
                    <textarea class="hidden w-full h-44 dark:bg-gray-700 bg-gray-50 text-black dark:text-white rounded-lg" id="translatedcontentarea"></textarea>
                </div>
                }
                <div id="htmlcontent" class="flex-1 overflow-y-auto px-4 py-2">
                    <div class="border-b border-gray-200 dark:border-gray-700 pb-2 pt-2" id="categories">
                        @foreach (var category in Model.PostViewModel.Categories)
                        {
                        <span class="inline-block rounded-full bg-blue-600 dark:bg-blue-700 px-3 py-1 mr-2 mb-1 font-body text-sm text-white">
                            @category
                        </span>
                        }
                    </div>
                    <h2 class="py-3 block font-body text-2xl font-semibold leading-tight text-gray-900 dark:text-white" id="title">@Model.PostViewModel?.Title</h2>
                    <p id="publishedDate" class="text-sm text-gray-500 dark:text-gray-400 pb-3">@(Model.PostViewModel?.PublishedDate  > default(DateTime) ? Model.PostViewModel?.PublishedDate.ToString("D")  : "")</p>
                    <div class="prose prose-sm max-w-none text-gray-800 dark:prose-invert dark:text-gray-200" id="renderedcontent">
                        @Html.Raw(Model.PostViewModel?.HtmlContent)
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>