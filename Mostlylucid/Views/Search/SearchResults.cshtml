@model Mostlylucid.Models.Search.SearchResultsModel
@using Mostlylucid.Models.Search
@using Htmx

@{
    // Don't use layout for HTMX partial requests
    if (!Context.Request.IsHtmx())
    {
        Layout = "_Layout";
    }
    ViewBag.Title = "Search Results";
    ViewBag.Description = "Search through technical articles on ASP.NET Core, C#, Entity Framework, and web development. Find tutorials, guides, and solutions.";
}

<form
    x-data="{
        query: '@Model.Query',
        autoSearch: true,
        checkSubmit() {
            if (this.autoSearch && this.query.length > 2) {
                $refs.searchButton.click();
            }
        }
    }"
    class="space-y-2"
    action="@Url.Action("Search", "Search")"
    hx-push-url="true"
    hx-boost="true"
    hx-target="#contentcontainer"
    hx-swap="innerHTML show:window:top">

    <!-- Main search bar -->
    <div class="flex items-center gap-2 bg-neutral-500 bg-opacity-10 p-2 rounded-lg">
        <button
            type="submit"
            x-ref="searchButton"
            class="btn btn-outline btn-sm flex items-center gap-2 text-black dark:text-white">
            Search
            <i class="bx bx-search text-lg"></i>
        </button>
        <label class="flex items-center gap-2">
            <input
                type="checkbox"
                x-model="autoSearch"
                class="checkbox checkbox-primary checkbox-sm"
            />
            <span class="text-black dark:text-white text-sm">Auto</span>
        </label>
        <input
            type="text"
            placeholder="Search..."
            name="query"
            id="searchQuery"
            value="@Model.Query"
            x-model="query"
            x-on:input.debounce.200ms="checkSubmit"
            x-on:keydown.enter.prevent="$refs.searchButton.click()"
            class="input input-sm border-0 grow text-black dark:text-white bg-transparent focus:outline-none"
        />
    </div>
</form>

<!-- Filter Bar - below search, always visible -->
<div class="flex justify-center my-4 print:!hidden">
    <partial name="_FilterBar" model="Model.SearchResults"/>
</div>

@if(Model.Query?.Length > 0)
{
    <partial name="_SearchResultsPartial" model="Model.SearchResults"></partial>
}
else
{
    <div id="content" class="pt-2 h-1/2 text-center text-lg text-black dark:text-white" data-search-page>
        Please enter a search term.
    </div>
}
