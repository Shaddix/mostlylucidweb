@using Mostlylucid.Shared.Helpers
@model (string slug, string[] languages, string? selectedLanguage)

@if (Model.languages != null && Model.languages.Length > 1)
{
    <div class="hidden sm:inline-flex items-center gap-0 px-1.5 py-0.5 bg-grey-lighter/50 dark:bg-gray-800 rounded-full border border-grey-light/30 dark:border-grey-dark/30">
        @foreach (var language in Model.languages)
        {
            var active = language == Model.selectedLanguage
                ? "opacity-100 ring-1 ring-blue-500 dark:ring-blue-400 scale-105"
                : "opacity-50 hover:opacity-90 hover:scale-105";

            <div class="tooltip" data-tip="@language.ConvertCodeToLanguage()">
                <a hx-controller="Blog"
                   hx-action="Language"
                   hx-route-slug="@Model.slug"
                   hx-route-language="@language"
                   hx-get
                   hx-target="#contentcontainer"
                   hx-swap="show:window:top"
                   hx-push-url="true"
                   onclick="saveLanguagePreference('@language')"
                   class="inline-block rounded @active transition-all duration-200 hover:-translate-y-0.5">
                    <img src="~/img/flags/@(language).svg"
                         width="18"
                         height="12"
                         asp-append-version="true"
                         alt="@language.ConvertCodeToLanguage()"
                         class="rounded shadow-sm" />
                </a>
            </div>
        }
    </div>
}

<script>
function saveLanguagePreference(lang) {
    try {
        localStorage.setItem('preferredLanguage', lang);
        const expires = new Date();
        expires.setFullYear(expires.getFullYear() + 1);
        document.cookie = `preferredLanguage=${lang}; path=/; expires=${expires.toUTCString()}; SameSite=Lax`;
    } catch(e) {
        console.warn('Could not save language preference:', e);
    }
}
</script>
