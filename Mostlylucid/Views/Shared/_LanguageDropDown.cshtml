@using Mostlylucid.Helpers
@using Mostlylucid.Shared.Helpers
@using Mostlylucid.Shared
@using Mostlylucid.Services.Markdown
@model List<string>

@{
    // Get all supported languages from LanguageConverter (includes pt, pl, etc.)
    var allSupportedLanguages = LanguageConverter.LanguageMap.Keys.ToList();

    // Build a robust, sanitized languages list: prefer the incoming model; if empty, fall back to cached pages
    var inputLangs = (Model ?? new List<string>());
    if (inputLangs.Count == 0)
    {
        try
        {
            var cache = PageCacheHelper.GetPageCache();
            inputLangs = cache.Values
                .SelectMany(p => p.Languages ?? Array.Empty<string>())
                .Concat(new[]{"en"})
                .ToList();
        }
        catch
        {
            inputLangs = new List<string>{"en"};
        }
    }

    // Merge with all supported languages so the dropdown always shows all options
    inputLangs = inputLangs
        .Concat(allSupportedLanguages)
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Select(s => s.Trim().ToLowerInvariant())
        .Distinct()
        .OrderBy(x => x)
        .ToList();
    if (!inputLangs.Contains("en"))
    {
        inputLangs.Add("en");
    }

    var langMap = inputLangs
        .Distinct()
        .ToDictionary(k => k, v => v.ConvertCodeToLanguage());
    var langMapJson = System.Text.Json.JsonSerializer.Serialize(langMap);
    var optsJson = System.Text.Json.JsonSerializer.Serialize(inputLangs);
}

<div id="LanguageDropDown"
     data-languages='@Html.Raw(optsJson)'
     data-language-map='@Html.Raw(langMapJson)'
     x-data="{
        open: false,
        selectedLanguage: 'Select Language',
        selectedFlag: '',
        selectedShortCode: '',
        _initialized: false,
        init() {
            // Guard against double initialization (HTMX + Alpine can cause this)
            if (this._initialized) return;
            this._initialized = true;
            // Priority: 1. localStorage, 2. URL param, 3. default to 'en'
            const url = new URL(window.location.href);
            const fromStorage = localStorage.getItem('preferredLanguage');
            const fromUrl = url.searchParams.get('language');
            const fromCookie = this.getCookie('preferredLanguage');

            // Use stored preference if no explicit URL param
            const languageToUse = (fromUrl || fromStorage || fromCookie || 'en').toLowerCase();

            const opts = JSON.parse(this.$el.dataset.languages || '[]');
            const has = opts.includes(languageToUse) ? languageToUse : (opts.includes('en') ? 'en' : (opts[0] || 'en'));

            this.selectedShortCode = has;
            const labelMap = JSON.parse(this.$el.dataset.languageMap || '{}');
            this.selectedLanguage = labelMap[has] || 'Select Language';
            this.selectedFlag = `/img/flags/${has}.svg`;

            // Save initial preference
            this.saveLanguagePreference(has);

            // Set hidden input value only (don't navigate on init)
            const hidden = document.getElementById('languageSelect');
            if (hidden) { hidden.value = has; }

            // Watch for changes and emit 'change' for external listeners
            this.$watch('selectedShortCode', (val) => {
                if (!val) return;
                // Save the preference
                this.saveLanguagePreference(val);
                const el = document.getElementById('languageSelect');
                if (el) {
                    el.value = val;
                    el.dispatchEvent(new Event('change'));
                }
            });
        },
        saveLanguagePreference(lang) {
            // Save to both localStorage and cookie for redundancy
            try {
                localStorage.setItem('preferredLanguage', lang);
                // Set cookie with 1 year expiry
                const expires = new Date();
                expires.setFullYear(expires.getFullYear() + 1);
                document.cookie = `preferredLanguage=${lang}; path=/; expires=${expires.toUTCString()}; SameSite=Lax`;
            } catch(e) {
                console.warn('Could not save language preference:', e);
            }
        },
        getCookie(name) {
            const value = `; ${document.cookie}`;
            const parts = value.split(`; ${name}=`);
            if (parts.length === 2) return parts.pop().split(';').shift();
            return null;
        }
     }"
     class="relative inline-block">
@{
        var isSearchPage = ViewContext.RouteData.Values["controller"]?.ToString()?.Equals("Search", StringComparison.OrdinalIgnoreCase) == true;
        var langTargetUrl = isSearchPage ? "/search" : "/blog";
    }
    <!-- Hidden input used by existing JS listeners and hx-include -->
    <input type="hidden" id="languageSelect" name="language"
           hx-get="@langTargetUrl"
           hx-target="#content"
           hx-swap="outerHTML show:none"
           hx-trigger="change"
           hx-push-url="true"
           hx-include="@(isSearchPage ? "#orderSelect, #searchQuery" : "#orderSelect, #categorySelect")"
           hx-vals='{"page": "1"}' />

    <!-- Dropdown Button -->
    <button x-on:click="open = !open"
            type="button"
            class="btn btn-sm btn-outline flex items-center gap-2 bg-white text-gray-800 border-gray-300 dark:bg-gray-800 dark:text-gray-100 dark:border-gray-600 hover:border-gray-400 dark:hover:border-gray-500 transition-colors min-w-[140px]">
        <!-- Dynamically Show the Flag Icon (use x-show instead of x-if to prevent duplication) -->
        <img x-show="selectedFlag" :src="selectedFlag" class="h-4 w-4 rounded outline outline-1 outline-gray-400 dark:outline-gray-300" alt="Selected Language Flag">
        <span x-text="selectedLanguage" class="flex-1 text-left truncate"></span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
    </button>

    <!-- Dropdown Menu -->
    <div x-show="open"
         x-on:click.away="open = false"
         x-transition:enter="transition ease-out duration-100"
         x-transition:enter-start="transform opacity-0 scale-95"
         x-transition:enter-end="transform opacity-100 scale-100"
         x-transition:leave="transition ease-in duration-75"
         x-transition:leave-start="transform opacity-100 scale-100"
         x-transition:leave-end="transform opacity-0 scale-95"
         class="absolute left-0 mt-2 w-64 rounded-md shadow-lg bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 dark:ring-gray-600 z-50 max-h-96 overflow-y-auto"
         style="display: none;">
        <ul class="p-2">
            @foreach (var language in inputLangs)
            {
                var label = language.ConvertCodeToLanguage();
            <li>
                <a href="#"
                   x-on:click.prevent="selectedLanguage='@label'; selectedFlag='/img/flags/@(language).svg'; selectedShortCode='@language'; open=false"
                   class="flex items-center gap-3 p-2 rounded hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-white text-gray-800 transition-colors">
                    <img src="/img/flags/@(language).svg" asp-append-version="true" width="16" height="16" class="h-4 w-4 rounded outline outline-1 outline-gray-400 dark:outline-gray-300 shrink-0" alt="@language">
                    <span>@label</span>
                </a>
            </li>
            }
        </ul>
    </div>
</div>