@using Mostlylucid.Models.Comments
@model Mostlylucid.Models.Comments.CommentViewList

@{
    List<CommentViewModel> GetOrderedComments(List<CommentViewModel> all, int parentId)
    {
        var result = new List<CommentViewModel>();
        foreach (var c in all.Where(x => x.ParentId == parentId).OrderBy(x => x.Date))
        {
            result.Add(c);
            result.AddRange(GetOrderedComments(all, c.Id));
        }
        return result;
    }
}

@foreach (var comment in GetOrderedComments(Model.Comments, 0))
{
    <partial name="_CommentDisplayModel" model="comment" />
}
