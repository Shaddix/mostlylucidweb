@model Mostlylucid.Shared.Models.AnnouncementDto

<div id="announcement-wrapper"
     x-data="{ dismissed: false }"
     x-show="!dismissed"
     x-transition:enter="transition-all ease-out duration-300"
     x-transition:enter-start="opacity-0 -translate-y-full"
     x-transition:enter-end="opacity-100 translate-y-0"
     x-transition:leave="transition-all ease-in duration-200"
     x-transition:leave-start="opacity-100 translate-y-0"
     x-transition:leave-end="opacity-0 -translate-y-full"
     class="transform">
    <div id="announcement-banner"
         class="bg-gradient-to-r from-blue-600 to-blue-800 dark:from-blue-800 dark:to-blue-900 text-white px-4 py-3 shadow-lg">
        <div class="container mx-auto flex items-center justify-between gap-4">
            <div class="flex-1 prose prose-invert prose-sm max-w-none [&>p]:m-0 [&>p]:text-white [&_a]:text-blue-200 [&_a:hover]:text-white">
                @Html.Raw(Model.HtmlContent)
            </div>
            <button type="button"
                    class="flex-shrink-0 p-1 rounded-full hover:bg-white/20 transition-colors focus:outline-none focus:ring-2 focus:ring-white/50"
                    title="Dismiss"
                    x-on:click="dismissed = true; fetch('/announcement/dismiss?key=@Model.Key', { method: 'POST' })"
                    aria-label="Dismiss announcement">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
    </div>
</div>
