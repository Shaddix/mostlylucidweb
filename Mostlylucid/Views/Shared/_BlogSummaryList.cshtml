@model Mostlylucid.Models.Blog.PostListViewModel
<div class="pt-4" id="content">


    <!-- Filter Controls Bar -->
    <div class=" rounded-lg p-4 mb-6 print:!hidden border border-gray-200 dark:border-gray-700">
        <div class="flex flex-col w-full gap-3">
            <partial name="_FilterBar" model="Model"></partial>

            <!-- Bottom row: Pagination (border-top only on lg+ when filters are visible) -->
            <div class="flex items-center justify-center w-full pt-2 lg:border-t border-gray-200 dark:border-gray-700">
                <paging
                    hx-boost="true"
                    class="shrink-0"
                    hx-target="#content"
                    hx-push-url="false"
                    hx-swap="show:none"
                    hx-headers='{"pagerequest": "true"}'
                    model="@Model">
                </paging>
            </div>
        </div>
    </div>

    @if (ViewBag.Categories != null)
    {
        <div class="mb-6 mt-2" x-data="blogCategories()">
            <div class="collapse collapse-arrow border border-neutral-400 dark:border-neutral-600 rounded-lg bg-gray-200 dark:bg-gray-800">
                <input 
                    type="checkbox" 
                    x-model="openCategories"
                    class="sr-only"
                />
            
                <!-- Added flex and items-center to collapse-title -->
                <div class="collapse-title p-0 min-h-0 text-lg font-medium text-base-content flex items-center">
                    <div class="px-5 py-2 bg-neutral-500 bg-opacity-10 rounded-lg font-body text-primary dark:text-white w-full cursor-pointer"
                         x-on:click="openCategories = !openCategories">
                        Categories
                    </div>
                </div>
            
                <div class="collapse-content flex flex-wrap pl-5 pr-5 bg-gray-200 dark:bg-gray-700" hx-boost="false">
                    <div class="pt-2 pb-2 gap-2 flex flex-wrap">
                        @foreach (var category in ViewBag.Categories)
                        {
                            <partial name="_Category" model="category"/>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    
    <text>
    @foreach (var post in Model.Data)
    {
        <partial name="_ListPost" model="post"/>
    }
    </text>

    <!-- Bottom Pagination -->
    <div class="flex items-center justify-center w-full mt-6 mb-4 print:!hidden">
        <paging
            hx-boost="true"
            class="shrink-0"
            hx-target="#content"
            hx-push-url="false"
            hx-swap="show:none"
            hx-headers='{"pagerequest": "true"}'
            model="@Model">
        </paging>
    </div>
</div>