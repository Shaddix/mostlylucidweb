@model Mostlylucid.Models.Blog.PostListViewModel
<div class="pt-4" id="content">


    <!-- Filter Controls Bar -->
    <div class="bg-gray-50 dark:bg-gray-800/50 rounded-lg p-4 mb-6 print:!hidden border border-gray-200 dark:border-gray-700">
        <div class="flex flex-col w-full gap-3">
            <!-- Top row: Filters -->
            <div class="flex flex-col lg:flex-row w-full gap-3 items-center justify-center">
                <!-- Date Range Filter -->
                <div class="flex items-center gap-2 shrink-0">
                    <label class="text-xs font-medium text-gray-600 dark:text-gray-400 hidden lg:block">Date:</label>
                    <input id="dateRange" type="text" placeholder="Filter by date range"
                           class="input input-bordered input-sm w-52 bg-white text-gray-800 border-gray-300 placeholder-gray-500 dark:bg-gray-800 dark:text-gray-100 dark:border-gray-600 dark:placeholder-gray-400 focus:border-blue-500 dark:focus:border-blue-400 transition-colors" />
                    <button id="clearDateFilter"
                            class="btn btn-outline btn-sm text-gray-700 border-gray-300 dark:text-gray-100 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all">
                        Clear
                    </button>
                </div>

                <!-- Language & Order Filters -->
                <div class="flex items-center gap-2 shrink-0 relative">
                    <label class="text-xs font-medium text-gray-600 dark:text-gray-400 hidden lg:block">Language:</label>
                    @{
                        var langs = Model?.Data?.SelectMany(p => p.Languages ?? Array.Empty<string>()).Concat(new[]{"en"}).Distinct(StringComparer.OrdinalIgnoreCase).ToList() ?? new List<string>{"en"};
                    }
                    <partial name="_LanguageDropDown" model="langs" />
                </div>

                <div class="flex items-center gap-2 shrink-0">
                    <label class="text-xs font-medium text-gray-600 dark:text-gray-400 hidden lg:block">Sort:</label>
                    <select id="orderSelect"
                            class="select select-bordered select-sm bg-white text-gray-800 border-gray-300 dark:bg-gray-800 dark:text-gray-100 dark:border-gray-600 hover:border-gray-400 dark:hover:border-gray-500 focus:border-blue-500 dark:focus:border-blue-400 transition-colors cursor-pointer">
                        <option value="date_desc">Newest first</option>
                        <option value="date_asc">Oldest first</option>
                        <option value="title_asc">Title A–Z</option>
                        <option value="title_desc">Title Z–A</option>
                    </select>
                </div>

                <!-- Filter Summary -->
                <div class="flex items-center text-sm text-gray-700 dark:text-gray-300 lg:ml-4 px-3 py-1.5 bg-white dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-600" id="filterSummary" aria-live="polite"></div>
            </div>

            <!-- Bottom row: Pagination -->
            <div class="flex items-center justify-center w-full pt-2 border-t border-gray-200 dark:border-gray-700">
                <paging
                    hx-boost="true"
                    class="shrink-0"
                    hx-target="#content"
                    hx-push-url="false"
                    hx-swap="show:none"
                    hx-headers='{"pagerequest": "true"}'
                    model="@Model">
                </paging>
            </div>
        </div>
    </div>

    @if (ViewBag.Categories != null)
    {
        <div class="mb-8 mt-6" x-data="blogCategories()">
            <div class="collapse collapse-arrow border border-neutral-400 dark:border-neutral-600 rounded-lg bg-gray-200 dark:bg-gray-800">
                <input 
                    type="checkbox" 
                    x-model="openCategories"
                    class="sr-only"
                />
            
                <!-- Added flex and items-center to collapse-title -->
                <div class="collapse-title p-0 min-h-0 text-lg font-medium text-base-content flex items-center">
                    <div class="px-5 py-2 bg-neutral-500 bg-opacity-10 rounded-lg font-body text-primary dark:text-white w-full cursor-pointer"
                         x-on:click="openCategories = !openCategories">
                        Categories
                    </div>
                </div>
            
                <div class="collapse-content flex flex-wrap pl-5 pr-5 bg-gray-200 dark:bg-gray-700" hx-boost="false">
                    <div class="pt-2 pb-2 gap-2 flex flex-wrap">
                        @foreach (var category in ViewBag.Categories)
                        {
                            <partial name="_Category" model="category"/>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    
    <text>
    @foreach (var post in Model.Data)
    {
        <partial name="_ListPost" model="post"/>
    }
    </text>
</div>