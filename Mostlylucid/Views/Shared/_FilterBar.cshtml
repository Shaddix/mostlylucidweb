@model Mostlylucid.Models.Blog.PostListViewModel

            <!-- Top row: Filters (hidden on mobile, shown on lg+) -->
            <div class="hidden lg:flex flex-row w-full gap-3 items-center justify-center">

                <a href="/blog" hx-boost="true" hx-target="#contentcontainer" hx-push-url="true"
                   class="btn btn-outline btn-sm text-gray-700 border-gray-300 dark:text-gray-100 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all hidden xl:inline-flex">
                    <i class='bx bx-book-reader mr-2'></i>Blog Posts
                </a>
                <a href="/rss" target="_blank"
                   class="btn btn-outline btn-sm text-gray-700 border-gray-300 dark:text-gray-100 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all hidden 2xl:inline-flex">
                    <i class="bx bx-rss mr-2"></i>RSS
                </a>
                <a asp-action="Edit" asp-controller="Editor"
                   class="btn btn-outline btn-sm text-gray-700 border-gray-300 dark:text-gray-100 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all hidden 2xl:inline-flex">
                    <i class="bx bx-edit mr-2"></i>New Post(ish)
                </a>
                <!-- Clear All Button (far left) -->
                <div class="shrink-0">
                    <clear-param all="true" target="#content">Clear All</clear-param>
                </div>

                <!-- Date Range Filter -->
                <div class="flex items-center gap-2 shrink-0">
                    <label class="text-xs font-medium text-gray-600 dark:text-gray-400 hidden lg:block">Date:</label>
                    <input id="dateRange" type="text" placeholder="Filter by date range"
                           class="input input-bordered input-sm w-64 bg-white text-gray-800 border-gray-300 placeholder-gray-500 dark:bg-gray-800 dark:text-gray-100 dark:border-gray-600 dark:placeholder-gray-400 focus:border-blue-500 dark:focus:border-blue-400 transition-colors"/>
                </div>

                <!-- Language & Order Filters -->
                <div class="flex items-center gap-2 shrink-0 relative">
                    <label class="text-xs font-medium text-gray-600 dark:text-gray-400 hidden lg:block">Language:</label>
                    @{
                        var langs = Model?.Data?.SelectMany(p => p.Languages ?? Array.Empty<string>()).Concat(new[] { "en" }).Distinct(StringComparer.OrdinalIgnoreCase).ToList() ?? new List<string> { "en" };
                    }
                    <partial name="_LanguageDropDown" model="langs"/>
                </div>

                <!-- Category Filter -->
                <div class="flex items-center gap-2 shrink-0 relative" x-data="categoryDropdown()">
                    <label class="text-xs font-medium text-gray-600 dark:text-gray-400 hidden lg:block">Category:</label>
                    <div class="relative inline-block">
                        <button type="button"
                                x-on:click="open = !open"
                                class="btn btn-sm btn-outline flex items-center gap-2 bg-white text-gray-800 border-gray-300 dark:bg-gray-800 dark:text-gray-100 dark:border-gray-600 hover:border-gray-400 dark:hover:border-gray-500 transition-colors min-w-[140px]">
                            <span x-text="selectedCategory || 'All'" class="flex-1 text-left truncate"></span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </button>
                        <div x-show="open"
                             x-on:click.away="open = false"
                             x-transition:enter="transition ease-out duration-100"
                             x-transition:enter-start="transform opacity-0 scale-95"
                             x-transition:enter-end="transform opacity-100 scale-100"
                             x-transition:leave="transition ease-in duration-75"
                             x-transition:leave-start="transform opacity-100 scale-100"
                             x-transition:leave-end="transform opacity-0 scale-95"
                             class="absolute left-0 mt-2 w-64 rounded-md shadow-lg bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 dark:ring-gray-600 z-50 max-h-64 overflow-y-auto"
                             style="display: none;">
                            <ul class="p-2">
                                <li>
                                    <a href="#"
                                       x-on:click.prevent="selectCategory(null); open = false"
                                       class="flex items-center justify-between p-2 rounded hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-white text-gray-800 transition-colors"
                                       :class="{ 'bg-gray-100 dark:bg-gray-700': !selectedCategory }">
                                        <span>All Categories</span>
                                    </a>
                                </li>
                                <template x-for="cat in categories" :key="cat.name">
                                    <li>
                                        <a href="#"
                                           x-on:click.prevent="selectCategory(cat.name); open = false"
                                           class="flex items-center justify-between p-2 rounded hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-white text-gray-800 transition-colors"
                                           :class="{ 'bg-gray-100 dark:bg-gray-700': selectedCategory === cat.name }">
                                            <span x-text="cat.name" class="truncate"></span>
                                            <span class="badge badge-sm badge-ghost" x-text="cat.postCount"></span>
                                        </a>
                                    </li>
                                </template>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="flex items-center gap-2 shrink-0">
                    <label class="text-xs font-medium text-gray-600 dark:text-gray-400 hidden lg:block">Sort:</label>
                    <select id="orderSelect"
                            class="select select-bordered select-sm bg-white text-gray-800 border-gray-300 dark:bg-gray-800 dark:text-gray-100 dark:border-gray-600 hover:border-gray-400 dark:hover:border-gray-500 focus:border-blue-500 dark:focus:border-blue-400 transition-colors cursor-pointer">
                        <option value="date_desc">Newest first</option>
                        <option value="date_asc">Oldest first</option>
                        <option value="title_asc">Title A–Z</option>
                        <option value="title_desc">Title Z–A</option>
                    </select>
                </div>

                <!-- Filter Summary -->
                <div class="flex items-center text-sm text-gray-700 dark:text-gray-300 lg:ml-4 px-3 py-1.5 bg-white dark:bg-gray-800 rounded border border-gray-200 dark:border-gray-600" id="filterSummary" aria-live="polite"></div>
            </div>