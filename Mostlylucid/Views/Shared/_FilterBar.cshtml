@model Mostlylucid.Models.Blog.PostListViewModel
@{
    var targetUrl = Context.Request.Path.Value ?? "/";
    var isSearchPage = targetUrl.StartsWith("/search", StringComparison.OrdinalIgnoreCase);
    var langs = Model?.Data?.SelectMany(p => p.Languages ?? Array.Empty<string>()).Concat(new[] { "en" }).Distinct(StringComparer.OrdinalIgnoreCase).ToList() ?? new List<string> { "en" };
}
<div x-data="{ showFilters: false }" @(isSearchPage ? "data-search-page" : "")>
    <!-- Mobile Filter Toggle (shown on mobile only) -->
    <div class="flex lg:hidden items-center justify-center gap-2 mb-2">
        <button type="button"
                x-on:click="showFilters = !showFilters"
                class="btn btn-outline btn-sm flex items-center gap-1"
                x-bind:class="showFilters ? 'btn-active' : ''">
            <i class="bx bx-filter text-lg"></i>
            <span class="text-sm">Filters</span>
            <i class="bx" x-bind:class="showFilters ? 'bx-chevron-up' : 'bx-chevron-down'"></i>
        </button>
        <a href="/blog" hx-boost="true" hx-target="#contentcontainer" hx-push-url="true"
           class="btn btn-outline btn-sm text-gray-700 border-gray-300 dark:text-gray-100 dark:border-gray-600">
            <i class='bx bx-book-reader'></i>
        </a>
    </div>

    <!-- Filter Controls - collapsible on mobile, always visible on desktop -->
    <div x-bind:class="showFilters ? '' : 'hidden lg:flex'"
         class="flex-wrap gap-2 items-center justify-center lg:flex bg-base-200 lg:bg-transparent dark:bg-gray-800 lg:dark:bg-transparent p-3 lg:p-0 rounded-lg lg:rounded-none mb-3 lg:mb-0">
                <a href="/blog" hx-boost="true" hx-target="#contentcontainer" hx-push-url="true"
                   class="btn btn-outline btn-sm text-gray-700 border-gray-300 dark:text-gray-100 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all hidden xl:inline-flex">
                    <i class='bx bx-book-reader mr-2'></i>Blog Posts
                </a>
                <a href="/rss" target="_blank"
                   class="btn btn-outline btn-sm text-gray-700 border-gray-300 dark:text-gray-100 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all hidden 2xl:inline-flex">
                    <i class="bx bx-rss mr-2"></i>RSS
                </a>
                <a asp-action="Edit" asp-controller="Editor"
                   class="btn btn-outline btn-sm text-gray-700 border-gray-300 dark:text-gray-100 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700 transition-all hidden 2xl:inline-flex">
                    <i class="bx bx-edit mr-2"></i>New Post(ish)
                </a>
                <clear-param all="true" target="#content">Clear All</clear-param>

                <!-- Date Range Filter -->
                <div class="flex items-center gap-1">
                    <label class="text-xs font-medium text-gray-600 dark:text-gray-400">Date:</label>
                    <input id="dateRange" type="text" placeholder="Date range"
                           class="input input-bordered input-sm w-48 bg-white text-gray-800 border-gray-300 placeholder-gray-500 dark:bg-gray-800 dark:text-gray-100 dark:border-gray-600 dark:placeholder-gray-400 focus:border-blue-500 dark:focus:border-blue-400 transition-colors"/>
                </div>

                <!-- Language -->
                <div class="flex items-center gap-1">
                    <label class="text-xs font-medium text-gray-600 dark:text-gray-400">Lang:</label>
                    <partial name="_LanguageDropDown" model="langs"/>
                </div>

                @if (!isSearchPage)
                {
                <!-- Category (blog only) -->
                <div class="flex items-center gap-1">
                    <label class="text-xs font-medium text-gray-600 dark:text-gray-400">Cat:</label>
                    <select id="categorySelect" name="category"
                            hx-get="@targetUrl"
                            hx-target="#content"
                            hx-swap="outerHTML show:none"
                            hx-trigger="change"
                            hx-push-url="true"
                            hx-include="#languageSelect, #orderSelect"
                            hx-vals='{"page": "1"}'
                            class="select select-bordered select-sm bg-white text-gray-800 border-gray-300 dark:bg-gray-800 dark:text-gray-100 dark:border-gray-600 transition-colors cursor-pointer">
                        <option value="">All</option>
                        @foreach (var cat in Model?.AllCategories ?? new List<Mostlylucid.Shared.Models.CategoryWithCount>())
                        {
                            <option value="@cat.Name">@cat.Name (@cat.PostCount)</option>
                        }
                    </select>
                </div>
                }

                <!-- Sort -->
                <div class="flex items-center gap-1">
                    <label class="text-xs font-medium text-gray-600 dark:text-gray-400">Sort:</label>
                    <select id="orderSelect" name="order"
                            hx-get="@targetUrl"
                            hx-target="#content"
                            hx-swap="outerHTML show:none"
                            hx-trigger="change"
                            hx-push-url="true"
                            hx-include="#languageSelect@(!isSearchPage ? ", #categorySelect" : ", #searchQuery")"
                            hx-vals='{"page": "1"}'
                            class="select select-bordered select-sm bg-white text-gray-800 border-gray-300 dark:bg-gray-800 dark:text-gray-100 dark:border-gray-600 transition-colors cursor-pointer">
                        @if (isSearchPage)
                        {
                            <option value="relevance" selected>Best Match</option>
                            <option value="date_desc">Newest</option>
                        }
                        else
                        {
                            <option value="date_desc" selected>Newest</option>
                        }
                        <option value="date_asc">Oldest</option>
                        <option value="title_asc">A–Z</option>
                        <option value="title_desc">Z–A</option>
                    </select>
                </div>
            </div>
</div>