@model List<Mostlylucid.Workflow.Shared.Models.WorkflowDefinition>

@{
    ViewBag.Title = "Workflows";
    Layout = "_Layout";
}

<div class="container mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-4xl font-bold text-base-content">
            ⚡ Workflow System
        </h1>
        <a href="/workflow/create" class="btn btn-primary">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Create Workflow
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card bg-base-200 shadow-xl">
            <div class="card-body items-center text-center">
                <h2 class="card-title text-2xl">No workflows yet!</h2>
                <p class="text-base-content/70">Get started by creating your first workflow.</p>
                <div class="card-actions">
                    <a href="/workflow/create" class="btn btn-primary mt-4">Create Your First Workflow</a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var workflow in Model)
            {
                <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
                    <div class="card-body">
                        <h2 class="card-title">
                            @workflow.Name
                            @if (!workflow.IsEnabled)
                            {
                                <div class="badge badge-ghost">Disabled</div>
                            }
                            else
                            {
                                <div class="badge badge-success">Enabled</div>
                            }
                        </h2>

                        @if (!string.IsNullOrEmpty(workflow.Description))
                        {
                            <p class="text-base-content/70">@workflow.Description</p>
                        }

                        <div class="flex flex-wrap gap-2 mt-2">
                            @foreach (var tag in workflow.Tags)
                            {
                                <span class="badge badge-outline">@tag</span>
                            }
                        </div>

                        <div class="stats stats-horizontal shadow mt-4">
                            <div class="stat p-4">
                                <div class="stat-title text-xs">Nodes</div>
                                <div class="stat-value text-lg">@workflow.Nodes.Count</div>
                            </div>
                            <div class="stat p-4">
                                <div class="stat-title text-xs">Version</div>
                                <div class="stat-value text-lg">@workflow.Version</div>
                            </div>
                        </div>

                        <div class="card-actions justify-end mt-4">
                            <button class="btn btn-sm btn-success"
                                    hx-post="/workflow/execute/@workflow.Id"
                                    hx-swap="none"
                                    hx-on::after-request="if(event.detail.successful) { alert('Workflow started!'); }">
                                ▶ Run
                            </button>
                            <a href="/workflow/edit/@workflow.Id" class="btn btn-sm btn-primary">
                                ✏️ Edit
                            </a>
                            <a href="/workflow/@workflow.Id/executions" class="btn btn-sm btn-info">
                                📊 History
                            </a>
                            <button class="btn btn-sm btn-error"
                                    hx-delete="/workflow/@workflow.Id"
                                    hx-confirm="Are you sure you want to delete this workflow?"
                                    hx-swap="none"
                                    hx-on::after-request="if(event.detail.successful) { window.location.reload(); }">
                                🗑️ Delete
                            </button>
                        </div>

                        <div class="text-xs text-base-content/50 mt-4">
                            Updated: @workflow.UpdatedAt.ToString("MMM dd, yyyy")
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
