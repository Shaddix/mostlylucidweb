@using Mostlylucid.Shared.Helpers
@using Mostlylucid.Helpers
@model Mostlylucid.Models.Blog.BlogPostViewModel
<title>@($"{Model.Title} ({Model.Language.ConvertCodeToLanguage()})")</title>
<div class="pt-2 lg:pt-2" id="blogpost" hx-boost="true"  hx-target="#contentcontainer" hx-swap="show:window:top">
    <div class="border-b border-grey-lighter pb-3 sm:pb-3">

        <h2 class="pb-2 block font-body text-3xl font-semibold leading-tight text-primary dark:text-white">
            @Model.Title
        </h2>

        @* Language Flags - Compact capsule right after title *@
        @if (Model.Languages.Length > 1)
        {
            var languageModel = (Model.Slug, Model.Languages, Model.Language);
            <div class="pb-2">
                <partial name="_LanguageFlags" model="languageModel"/>
            </div>
        }

        <div class="flex flex-wrap border-b border-grey-lighter items-center gap-x-2 gap-y-1 pb-2 pt-1 sm:pt-1">
            <p class="pr-2 font-body text-sm font-light text-primary dark:text-white">
                @Model.PublishedDate.ToString("D")
            </p>
            @if (Model.ShowUpdatedDate && Model.UpdatedDate.HasValue)
            {
                <span class="dark:text-white font-body text-grey text-sm">//</span>
                <p class="px-2 font-body text-sm font-light text-primary dark:text-white italic">
                    @UpdatedDateFormatter.Format(Model.UpdatedDate, Model.UpdatedTemplate)
                </p>
            }
            <span class="dark:text-white font-body text-grey text-sm">//</span>
            <p class="pl-2 font-body text-sm font-light text-primary dark:text-white">
                @Model.ReadingTime
            </p>
            <div class="pl-4 flex flex-wrap gap-2 items-center print:hidden">
                <a href="#commentsection" class="btn btn-outline btn-xs inline-flex items-center">
                    <i class="bx bx-mail-send"></i> Comments
                </a>

                <a href="/api/raw/@Model.Slug?language=@Model.Language"
                   target="_blank" rel="noopener"
                   class="btn btn-outline btn-xs inline-flex items-center"
                   title="View raw Markdown">
                    <i class="bx bx-code-alt"></i> Raw
                </a>

                <a asp-action="Edit"
                   asp-controller="Editor"
                   asp-route-slug="@Model.Slug"
                   asp-route-language="@Model.Language"
                   class="btn btn-outline btn-xs btn-primary inline-flex items-center">
                    <i class="bx bx-edit"></i> Edit
                </a>
            </div>
        </div>
        @if (Model.PreviousPost != null || Model.NextPost != null)
        {
            <nav class="flex items-center justify-between text-sm text-primary dark:text-white my-2 print:hidden" aria-label="Post navigation">
                <div>
                    @if (Model.PreviousPost != null)
                    {
                        @if (BlogUrlHelper.IsEnglish(Model.Language))
                        {
                            <a href="@Url.Action("Show", "Blog", new { slug = Model.PreviousPost.Slug })" hx-controller="Blog" hx-action="Show" hx-route-slug="@Model.PreviousPost.Slug" hx-get hx-target="#contentcontainer" hx-swap="show:window:top" hx-push-url="true" class="inline-flex items-center hover:text-secondary">
                                <i class='bx bx-left-arrow-alt text-xl mr-1'></i>
                                <span>Newer: @Model.PreviousPost.Title</span>
                            </a>
                        }
                        else
                        {
                            <a href="@Url.Action("Language", "Blog", new { slug = Model.PreviousPost.Slug, language = Model.Language })" hx-controller="Blog" hx-action="Language" hx-route-slug="@Model.PreviousPost.Slug" hx-route-language="@Model.Language" hx-get hx-target="#contentcontainer" hx-swap="show:window:top" hx-push-url="true" class="inline-flex items-center hover:text-secondary">
                                <i class='bx bx-left-arrow-alt text-xl mr-1'></i>
                                <span>Newer: @Model.PreviousPost.Title</span>
                            </a>
                        }
                    }
                </div>
                <div>
                    @if (Model.NextPost != null)
                    {
                        @if (BlogUrlHelper.IsEnglish(Model.Language))
                        {
                            <a href="@Url.Action("Show", "Blog", new { slug = Model.NextPost.Slug })" hx-controller="Blog" hx-action="Show" hx-route-slug="@Model.NextPost.Slug" hx-get hx-target="#contentcontainer" hx-swap="show:window:top" hx-push-url="true" class="inline-flex items-center hover:text-secondary">
                                <span>Older: @Model.NextPost.Title</span>
                                <i class='bx bx-right-arrow-alt text-xl ml-1'></i>
                            </a>
                        }
                        else
                        {
                            <a href="@Url.Action("Language", "Blog", new { slug = Model.NextPost.Slug, language = Model.Language })" hx-controller="Blog" hx-action="Language" hx-route-slug="@Model.NextPost.Slug" hx-route-language="@Model.Language" hx-get hx-target="#contentcontainer" hx-swap="show:window:top" hx-push-url="true" class="inline-flex items-center hover:text-secondary">
                                <span>Older: @Model.NextPost.Title</span>
                                <i class='bx bx-right-arrow-alt text-xl ml-1'></i>
                            </a>
                        }
                    }
                </div>
            </nav>
        }

        @* Compact Categories *@
        <div class="pb-2 pt-2 print:hidden flex flex-wrap gap-1.5">
            @foreach (var category in Model.Categories)
            {
                <partial name="_Category" model="category"/>
            }
        </div>

    </div>
    <div class="prose  dark:text-white text-black  max-w-none  py-2 mt-4 sm:py-2" >
        @Html.Raw(Model.HtmlContent)
    </div>
    @if (Model.PreviousPost != null || Model.NextPost != null)
    {
        <nav class="flex items-center justify-between text-sm text-primary dark:text-white mb-2 print:hidden" aria-label="Post navigation">
            <div>
                @if (Model.PreviousPost != null)
                {
                    @if (BlogUrlHelper.IsEnglish(Model.Language))
                    {
                        <a href="@Url.Action("Show", "Blog", new { slug = Model.PreviousPost.Slug })" hx-controller="Blog" hx-action="Show" hx-route-slug="@Model.PreviousPost.Slug" hx-get hx-target="#contentcontainer" hx-swap="show:window:top" hx-push-url="true" class="inline-flex items-center hover:text-secondary">
                            <i class='bx bx-left-arrow-alt text-xl mr-1'></i>
                            <span>Newer: @Model.PreviousPost.Title</span>
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("Language", "Blog", new { slug = Model.PreviousPost.Slug, language = Model.Language })" hx-controller="Blog" hx-action="Language" hx-route-slug="@Model.PreviousPost.Slug" hx-route-language="@Model.Language" hx-get hx-target="#contentcontainer" hx-swap="show:window:top" hx-push-url="true" class="inline-flex items-center hover:text-secondary">
                            <i class='bx bx-left-arrow-alt text-xl mr-1'></i>
                            <span>Newer: @Model.PreviousPost.Title</span>
                        </a>
                    }
                }
            </div>
            <div>
                @if (Model.NextPost != null)
                {
                    @if (BlogUrlHelper.IsEnglish(Model.Language))
                    {
                        <a href="@Url.Action("Show", "Blog", new { slug = Model.NextPost.Slug })" hx-controller="Blog" hx-action="Show" hx-route-slug="@Model.NextPost.Slug" hx-get hx-target="#contentcontainer" hx-swap="show:window:top" hx-push-url="true" class="inline-flex items-center hover:text-secondary">
                            <span>Older: @Model.NextPost.Title</span>
                            <i class='bx bx-right-arrow-alt text-xl ml-1'></i>
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("Language", "Blog", new { slug = Model.NextPost.Slug, language = Model.Language })" hx-controller="Blog" hx-action="Language" hx-route-slug="@Model.NextPost.Slug" hx-route-language="@Model.Language" hx-get hx-target="#contentcontainer" hx-swap="show:window:top" hx-push-url="true" class="inline-flex items-center hover:text-secondary">
                            <span>Older: @Model.NextPost.Title</span>
                            <i class='bx bx-right-arrow-alt text-xl ml-1'></i>
                        </a>
                    }
                }
            </div>
        </nav>
    }

    @* Related Posts Section - Loaded via HTMX *@
    <div class="print:hidden"
         hx-get="/search/related/@Model.Slug/@Model.Language"
         hx-trigger="load delay:300ms"
         hx-target="this"
         hx-swap="innerHTML">
        @* Loading placeholder *@
        <div class="mt-6 mb-6">
            <div class="border border-base-300 rounded-lg overflow-hidden bg-gradient-to-r from-base-200/80 to-base-200/40">
                <div class="flex items-center gap-2 px-4 py-2.5">
                    <span class="loading loading-spinner loading-xs text-secondary"></span>
                    <span class="text-sm opacity-60">Finding related posts...</span>
                </div>
            </div>
        </div>
    </div>

    <div x-data="{ showNewElement: false }" x-init="
    document.addEventListener('htmx:afterSwap', (event) => {
        if (event.detail.target.id === 'contentformarea') {
            $data.showNewElement = true;  // Use $data to reference Alpine component's state
        }
    });
"  class="pt-6 print:!hidden" id="commentsection">
        <!-- Button that will disappear once showNewElement is true -->
        <a x-show="!showNewElement"
           class="btn btm-sm btn-outline mb-6"
           href="javascript:void(0)"
           role="button"
           x-on:click.prevent
           hx-boost="false"
           hx-controller="Comment"
           hx-action="GetCommentForm"
           hx-route-postId="@(Int32.Parse(Model.Id))"
           hx-get
           hx-push-url="false"
           hx-swap="innerHTML"
           hx-target="#contentformarea">
            <i class='bx bx-message-rounded-add'></i> Add Comment
        </a>

        <!-- The target for HTMX content swap -->
        <div id="contentformarea"
             x-show="showNewElement"
             class="border border-b-neutral-600 border-1 rounded-xl p-4 mb-4">
        </div>
    </div>

    <div id="commentlist">
        
    
        <partial name="_ListComments" for="Comments"/>
    </div>
 
</div>