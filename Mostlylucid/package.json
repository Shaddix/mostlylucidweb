{
  "scripts": {
    "clean": "rimraf ./.tmp ./wwwroot/css/ ./wwwroot/js/",
    "dev": "npm-run-all clean dev:prepare dev:js",
    "dev:prepare": "npm-run-all --parallel dev:copy-once dev:tw-once",
    "dev:copy-once": "cpx \"src/css/easymde-overrides.css\" \"wwwroot/css/dist\" && cpx \"node_modules/highlight.js/styles/default.min.css\" \"wwwroot/css/highlight\" && cpx \"node_modules/highlight.js/styles/atom-one-dark-reasonable.min.css\" \"wwwroot/css/highlight\"",
    "dev:tw-once": "postcss ./src/css/main.css -o ./wwwroot/css/dist/main.css",
    "dev:js": "webpack --env development",
    "watch": "npm-run-all clean --parallel watch:copy watch:tw watch:js",
    "watch:copy": "cpx \"src/css/easymde-overrides.css\" \"wwwroot/css/dist\" --watch & cpx \"node_modules/highlight.js/styles/{default.min,atom-one-dark-reasonable.min}.css\" \"wwwroot/css/highlight\" --watch",
    "watch:tw": "postcss ./src/css/main.css -o ./wwwroot/css/dist/main.css --watch",
    "watch:js": "webpack watch --env development",
    "build": "npm-run-all clean build:prepare build:js",
    "build:prepare": "npm-run-all --parallel build:copy build:tw",
    "build:copy": "cpx \"src/css/easymde-overrides.css\" \"wwwroot/css/dist\" & cpx \"node_modules/highlight.js/styles/{default.min,atom-one-dark-reasonable.min}.css\" \"wwwroot/css/highlight\"",
    "build:tw": "postcss ./src/css/main.css -o ./wwwroot/css/dist/main.css --no-map --verbose",
    "build:js": "webpack --mode production"
  },
  "devDependencies": {
    "@babel/core": "7.26.9",
    "@babel/preset-env": "7.26.9",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.12",
    "autoprefixer": "10.4.21",
    "babel-loader": "10.0.0",
    "cpx": "1.5.0",
    "css-loader": "7.1.2",
    "cssnano": "7.0.6",
    "daisyui": "^4.12.10",
    "npm-run-all": "4.1.5",
    "postcss": "8.5.3",
    "postcss-cli": "11.0.1",
    "postcss-import": "^16.1.0",
    "rimraf": "6.0.1",
    "style-loader": "4.0.0",
    "tailwindcss": "3.4.17",
    "terser-webpack-plugin": "^5.3.10",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "alpinejs": "^3.14.1",
    "codemirror": "5.65.13",
    "core-js": "^3.39.0",
    "easymde": "2.20.0",
    "highlight.js": "^11.10.0",
    "highlightjs-cshtml-razor": "^2.1.1",
    "htmx.org": "^2.0.1",
    "mermaid": "^11.0.2",
    "regenerator-runtime": "^0.14.1"
  }
}
