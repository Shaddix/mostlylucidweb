{
  "TranslateService": {
    "Enabled": "true",
    "ServiceIPs": "http://localhost:8000",
    "AutoTranslateMode": "SaveToDisk",
    "ForceRetranslation": "true",
    "Languages": [
      "es",
      "fr",
      "de",
      "it",
      "zh",
      "nl",
      "hi",
      "ar",
      "uk",
      "fi",
      "sv",
      "el",
      "ms"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
"WriteTo": [
  {
    "Name": "Console"
  },
  {
    "Name": "File",
    "Args": {
      "path": "logs/applog-.txt",
      "rollingInterval": "Day",
      "retainedFileCountLimit": 3
    }
  }
]
  },
  
  "SmtpSettings":
  {
    "Server": "localhost",
    "Port": 2525,
    "SenderName": "Mostlylucid",
    "Username": "",
    "SenderEmail": "scott.galloway@gmail.com",
    "Password": "",
    "EnableSSL": "false",
    "EmailSendTry": 3,
    "EmailSendFailed": "true",
    "ToMail": "scott.galloway@gmail.com",
    "EmailSubject": "Mostlylucid"
    
  },
  "Blog": {
    "Mode": "Database"
  },
  "SemanticSearch": {
    "Enabled": true,
    "QdrantUrl": "http://localhost:6333",
    "CollectionName": "blog_posts",
    "EmbeddingModelPath": "mlmodels/all-MiniLM-L6-v2.onnx",
    "VocabPath": "mlmodels/vocab.txt",
    "VectorSize": 384,
    "RelatedPostsCount": 5,
    "MinimumSimilarityScore": 0.3,
    "SearchResultsCount": 10
  }
}