<Window x:Class="TinyLLM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TinyLLM - Local AI Chat with RAG" Height="700" Width="900"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Modern Dark Theme Styles -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3E3E42"/>
                    <Setter Property="Foreground" Value="#656565"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MessageBubbleUser" TargetType="Border">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="50,5,10,5"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="MessageBubbleAssistant" TargetType="Border">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="10,5,50,5"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Settings -->
        <Border Grid.Row="0" Background="#252526" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="TinyLLM" FontSize="20" FontWeight="Bold"
                              Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ModelStatusText" Text="Model not loaded"
                              FontSize="12" Foreground="#858585"
                              VerticalAlignment="Center" Margin="15,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Model:" Foreground="White" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ModelSelector" Width="200"
                             Background="#3E3E42" Foreground="White"
                             BorderBrush="#007ACC"
                             SelectionChanged="ModelSelector_SelectionChanged"/>

                    <Button Content="🔄" Click="RefreshModels_Click"
                           Style="{StaticResource ModernButton}"
                           Padding="8,5" ToolTip="Refresh available models"/>

                    <CheckBox x:Name="UseGpuCheckBox" Content="Use GPU"
                             Foreground="White" VerticalAlignment="Center"
                             Checked="UseGpuCheckBox_Changed"
                             Unchecked="UseGpuCheckBox_Changed"
                             Margin="10,0,0,0"/>

                    <CheckBox x:Name="UseRagCheckBox" Content="Use RAG"
                             IsChecked="True" Foreground="White"
                             VerticalAlignment="Center"/>

                    <TextBlock Foreground="#858585" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Run Text="RAG:"/>
                        <Run x:Name="RagCountText" Text="0" FontWeight="Bold"/>
                    </TextBlock>

                    <Button Content="Clear" Click="ClearRag_Click"
                           Style="{StaticResource ModernButton}"
                           Background="#C50F1F" Padding="8,5"
                           ToolTip="Clear RAG database"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Chat Messages Area -->
        <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer"
                     VerticalScrollBarVisibility="Auto"
                     Background="#1E1E1E">
            <ItemsControl x:Name="ChatMessagesPanel" Padding="10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{Binding Role, Converter={StaticResource RoleToStyleConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding Role, Converter={StaticResource RoleToDisplayConverter}}"
                                          FontSize="11" FontWeight="Bold"
                                          Foreground="#CCCCCC" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Content}"
                                          TextWrapping="Wrap"
                                          Foreground="White"
                                          FontSize="14"/>
                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                                          FontSize="10"
                                          Foreground="#858585"
                                          Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading/Progress Area -->
        <Border Grid.Row="2" x:Name="ProgressPanel" Background="#252526"
               Padding="15" Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="ProgressText" Text="Downloading model..."
                          Foreground="White" FontSize="14" Margin="0,0,0,10"/>
                <ProgressBar x:Name="DownloadProgressBar" Height="8"
                            Minimum="0" Maximum="100" Value="0"/>
                <TextBlock x:Name="ProgressDetailText" Text=""
                          Foreground="#858585" FontSize="12" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="3" Background="#252526" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInputTextBox"
                        Grid.Column="0"
                        Background="#3E3E42"
                        Foreground="White"
                        BorderBrush="#007ACC"
                        BorderThickness="2"
                        Padding="10"
                        FontSize="14"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        MaxHeight="100"
                        VerticalScrollBarVisibility="Auto"
                        KeyDown="UserInputTextBox_KeyDown"
                        Text="What can you help me with?"/>

                <Button x:Name="SendButton"
                       Grid.Column="1"
                       Content="Send"
                       Style="{StaticResource ModernButton}"
                       Margin="10,0,0,0"
                       Width="100"
                       Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
