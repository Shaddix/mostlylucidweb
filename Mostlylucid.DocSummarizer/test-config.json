{
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "ministral-3:3b",
    "EmbedModel": "nomic-embed-text",
    "Temperature": 0.3,
    "TimeoutSeconds": 300
  },
  "Docling": {
    "BaseUrl": "http://localhost:5001",
    "TimeoutSeconds": 300
  },
  "Qdrant": {
    "Host": "localhost",
    "Port": 6334,
    "CollectionName": "documents",
    "VectorSize": 768
  },
  "Processing": {
    "MaxHeadingLevel": 3,
    "RagTopK": 3,
    "RagMaxTopics": 8,
    "EnableParallel": true,
    "MaxDegreeOfParallelism": -1
  },
  "Output": {
    "Format": "Console",
    "IncludeTrace": true,
    "IncludeTopics": true,
    "IncludeOpenQuestions": true,
    "Verbose": false
  },
  "Batch": {
    "FileExtensions": [
      ".pdf",
      ".docx",
      ".md"
    ],
    "Recursive": false,
    "IncludePatterns": [
      "*"
    ],
    "ExcludePatterns": [],
    "ContinueOnError": true,
    "CreateIndex": true
  }
}