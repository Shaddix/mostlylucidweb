@{
    ViewData["Title"] = "Support Interface";
}

<header>
    <div class="container">
        <h1>Support Staff Interface</h1>
        <p>Active secure chat sessions</p>
    </div>
</header>

<main class="container">
    <div id="sessions-list" style="margin-bottom: 30px;">
        <h2>Waiting Sessions</h2>
        <div id="waiting-sessions" style="background: #f9f9f9; padding: 15px; border-radius: 4px; min-height: 100px;">
            <p style="color: #666;">No active sessions</p>
        </div>
    </div>

    <div id="active-chat" style="display: none;">
        <h2>Chat Session: <span id="active-session-id"></span></h2>
        <div style="background: white; border: 1px solid #ddd; border-radius: 4px; margin-bottom: 15px;">
            <div id="support-chat-body" style="height: 400px; overflow-y: auto; padding: 15px;">
                <!-- Messages appear here -->
            </div>
            <div style="padding: 15px; border-top: 1px solid #ddd;">
                <input type="text" id="support-message-input" placeholder="Type your message..."
                       style="width: calc(100% - 100px); padding: 10px; border: 1px solid #ddd; border-radius: 4px; margin-right: 10px;" />
                <button id="support-send-btn" style="width: 90px; padding: 10px; background: #0066cc; color: white; border: none; border-radius: 4px; cursor: pointer;">
                    Send
                </button>
                <button id="end-session-btn" style="width: 100%; padding: 10px; margin-top: 10px; background: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer;">
                    End Session
                </button>
            </div>
        </div>
    </div>
</main>

<style>
    .session-item {
        background: white;
        padding: 15px;
        margin-bottom: 10px;
        border-radius: 4px;
        border: 1px solid #ddd;
        cursor: pointer;
        transition: background 0.2s;
    }
    .session-item:hover {
        background: #f0f0f0;
    }
    .message {
        margin-bottom: 10px;
        padding: 8px 12px;
        border-radius: 8px;
        max-width: 80%;
        word-wrap: break-word;
    }
    .message.user {
        background: #0066cc;
        color: white;
        margin-left: auto;
        text-align: right;
    }
    .message.support {
        background: #f0f0f0;
        color: #333;
    }
    .message.system {
        background: #fff3cd;
        color: #856404;
        text-align: center;
        margin: 10px auto;
        font-style: italic;
        font-size: 0.9em;
    }
</style>

@section Scripts {
<script>
    let connection = null;
    let currentSessionId = null;

    async function initSupport() {
        try {
            connection = new signalR.HubConnectionBuilder()
                .withUrl('/securechat')
                .withAutomaticReconnect()
                .build();

            setupSupportHandlers();

            await connection.start();
            console.log('Support connected to hub');
        } catch (error) {
            console.error('Failed to connect:', error);
            setTimeout(initSupport, 5000); // Retry after 5 seconds
        }
    }

    function setupSupportHandlers() {
        connection.on('NewSessionAvailable', (sessionId, timestamp) => {
            console.log('New session available:', sessionId);
            addSessionToList(sessionId, timestamp);
        });

        connection.on('ReceiveMessage', (message) => {
            displaySupportMessage(message);
        });

        connection.on('ClientDisconnected', (sessionId) => {
            displaySupportSystemMessage('Client disconnected');
        });

        connection.on('SessionEnded', () => {
            displaySupportSystemMessage('Session ended');
            setTimeout(() => {
                document.getElementById('active-chat').style.display = 'none';
                currentSessionId = null;
            }, 2000);
        });
    }

    function addSessionToList(sessionId, timestamp) {
        const waitingSessions = document.getElementById('waiting-sessions');

        // Clear "no sessions" message if present
        if (waitingSessions.querySelector('p')) {
            waitingSessions.innerHTML = '';
        }

        const sessionEl = document.createElement('div');
        sessionEl.className = 'session-item';
        sessionEl.id = `session-${sessionId}`;
        sessionEl.innerHTML = `
            <strong>Session ID:</strong> ${sessionId}<br/>
            <strong>Started:</strong> ${new Date(timestamp).toLocaleTimeString()}
        `;
        sessionEl.onclick = () => joinSession(sessionId);

        waitingSessions.appendChild(sessionEl);
    }

    async function joinSession(sessionId) {
        try {
            const result = await connection.invoke('JoinSessionAsSupport', sessionId);

            if (result.success) {
                currentSessionId = sessionId;
                document.getElementById('active-session-id').textContent = sessionId;
                document.getElementById('active-chat').style.display = 'block';
                document.getElementById('support-chat-body').innerHTML = '<div class="message system">Connected to client</div>';

                // Remove from waiting list
                const sessionEl = document.getElementById(`session-${sessionId}`);
                if (sessionEl) {
                    sessionEl.remove();
                }

                // Check if waiting list is empty
                const waitingSessions = document.getElementById('waiting-sessions');
                if (!waitingSessions.querySelector('.session-item')) {
                    waitingSessions.innerHTML = '<p style="color: #666;">No active sessions</p>';
                }
            } else {
                alert('Failed to join session: ' + result.message);
            }
        } catch (error) {
            console.error('Failed to join session:', error);
            alert('Error joining session');
        }
    }

    async function sendSupportMessage() {
        const input = document.getElementById('support-message-input');
        const message = input.value.trim();

        if (!message || !currentSessionId) {
            return;
        }

        try {
            await connection.invoke('SendMessageAsSupport', currentSessionId, message);
            input.value = '';
        } catch (error) {
            console.error('Failed to send message:', error);
            displaySupportSystemMessage('Failed to send message');
        }
    }

    async function endCurrentSession() {
        if (!currentSessionId) {
            return;
        }

        if (!confirm('Are you sure you want to end this session?')) {
            return;
        }

        try {
            await connection.invoke('EndSession', currentSessionId);
        } catch (error) {
            console.error('Failed to end session:', error);
        }
    }

    function displaySupportMessage(message) {
        const chatBody = document.getElementById('support-chat-body');
        const messageEl = document.createElement('div');
        messageEl.className = `message ${message.fromSupport ? 'support' : 'user'}`;
        messageEl.textContent = message.message;

        chatBody.appendChild(messageEl);
        chatBody.scrollTop = chatBody.scrollHeight;
    }

    function displaySupportSystemMessage(text) {
        const chatBody = document.getElementById('support-chat-body');
        const messageEl = document.createElement('div');
        messageEl.className = 'message system';
        messageEl.textContent = text;

        chatBody.appendChild(messageEl);
        chatBody.scrollTop = chatBody.scrollHeight;
    }

    // Setup event listeners
    document.getElementById('support-send-btn').addEventListener('click', sendSupportMessage);
    document.getElementById('support-message-input').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
            sendSupportMessage();
        }
    });
    document.getElementById('end-session-btn').addEventListener('click', endCurrentSession);

    // Initialize on page load
    initSupport();
</script>
}
