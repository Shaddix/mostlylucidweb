@model Mostlylucid.Workflow.Shared.Models.WorkflowDefinition

@if (Model?.Nodes != null && Model.Nodes.Any())
{
    foreach (var node in Model.Nodes)
    {
        @await Html.PartialAsync("Partials/_WorkflowNode", node)
    }
}
else
{
    <div class="absolute inset-0 flex items-center justify-center text-base-content/30">
        <div class="text-center">
            <svg class="w-32 h-32 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
            <p class="text-2xl font-bold">Click a node type to add it to the canvas</p>
            <p class="text-lg mt-2">Start building your workflow</p>
        </div>
    </div>
}
